        self._add("marketplace", [["consumers", {"type": "participant", "power": "purchasing"}], ["products_offered", {"type": "option", "compete_for": "sales"}], ["market_forces", {"type": "mechanism", "selects": "survivors"}]], [["choose", ["consumers", "products_offered"], false], ["compete_for", ["products_offered", "revenue"], false], ["determines", ["market_forces", "winners"], false]])
        self.domain_pairs.append(["democracy", "marketplace"])

        self._add("neural_network", [["nodes", {"type": "unit", "function": "computation"}], ["connections", {"type": "link", "property": "weighted"}], ["activation", {"type": "signal", "function": "propagation"}]], [["transmit", ["connections", "activation"], false], ["aggregates", ["nodes", "inputs"], false], ["strengthens", ["learning", "connections"], true]])
        self._add("highway_system", [["intersections", {"type": "unit", "function": "routing"}], ["road_segments", {"type": "link", "property": "capacity-limited"}], ["vehicles", {"type": "signal", "function": "transport"}]], [["transmit", ["road_segments", "vehicles"], false], ["aggregates", ["intersections", "traffic_flows"], false], ["strengthens", ["expansion", "road_segments"], true]])
        self.domain_pairs.append(["neural_network", "highway_system"])

        self._add("forest_fire", [["fire", {"type": "agent", "behavior": "spreading"}], ["dry_brush", {"type": "fuel", "enables": "propagation"}], ["firebreak", {"type": "barrier", "function": "containment"}]], [["spreads_through", ["fire", "dry_brush"], false], ["consumes", ["fire", "fuel_source"], false], ["blocks", ["firebreak", "fire"], false]])
        self._add("epidemic", [["disease", {"type": "agent", "behavior": "spreading"}], ["susceptible_population", {"type": "fuel", "enables": "transmission"}], ["quarantine", {"type": "barrier", "function": "containment"}]], [["spreads_through", ["disease", "susceptible_population"], false], ["consumes", ["disease", "host_health"], false], ["blocks", ["quarantine", "disease"], false]])
        self.domain_pairs.append(["forest_fire", "epidemic"])

        self._add("pregnancy", [["embryo", {"type": "developing entity", "stage": "early"}], ["gestation", {"type": "process", "duration": "9 months"}], ["birth", {"type": "milestone", "marks": "completion"}]], [["develops_during", ["embryo", "gestation"], false], ["nourishes", ["placenta", "embryo"], false], ["culminates_in", ["gestation", "birth"], false]])
        self._add("project_development", [["prototype", {"type": "developing entity", "stage": "early"}], ["development_cycle", {"type": "process", "duration": "months"}], ["launch", {"type": "milestone", "marks": "completion"}]], [["develops_during", ["prototype", "development_cycle"], false], ["nourishes", ["funding", "prototype"], false], ["culminates_in", ["development_cycle", "launch"], false]])
        self.domain_pairs.append(["pregnancy", "project_development"])

        self._add("breathing", [["lungs", {"type": "organ", "function": "gas exchange"}], ["inhalation", {"type": "phase", "direction": "inward"}], ["exhalation", {"type": "phase", "direction": "outward"}]], [["draws_in", ["inhalation", "air"], false], ["expels", ["exhalation", "carbon_dioxide"], false], ["rhythmically_alternates", ["inhalation", "exhalation"], true]])
        self._add("tides", [["ocean_body", {"type": "body", "function": "water cycling"}], ["high_tide", {"type": "phase", "direction": "inward"}], ["low_tide", {"type": "phase", "direction": "outward"}]], [["draws_in", ["high_tide", "water"], false], ["expels", ["low_tide", "water"], false], ["rhythmically_alternates", ["high_tide", "low_tide"], true]])
        self.domain_pairs.append(["breathing", "tides"])

        self._add("language", [["words", {"type": "unit", "carries": "meaning"}], ["grammar", {"type": "structure", "governs": "arrangement"}], ["sentence", {"type": "composition", "expresses": "thought"}]], [["compose", ["words", "sentence"], false], ["governs", ["grammar", "word_arrangement"], false], ["conveys", ["sentence", "meaning"], false]])
        self._add("music", [["notes", {"type": "unit", "carries": "tone"}], ["harmony_rules", {"type": "structure", "governs": "arrangement"}], ["melody", {"type": "composition", "expresses": "emotion"}]], [["compose", ["notes", "melody"], false], ["governs", ["harmony_rules", "note_arrangement"], false], ["conveys", ["melody", "emotion"], false]])
        self.domain_pairs.append(["language", "music"])

        self._add("map", [["map_features", {"type": "representation", "of": "terrain"}], ["scale", {"type": "ratio", "connects": "map to territory"}], ["legend", {"type": "key", "translates": "symbols"}]], [["represents", ["map_features", "territory"], false], ["reduces", ["scale", "complexity"], false], ["interprets", ["legend", "map_features"], false]])
        self._add("model", [["parameters", {"type": "representation", "of": "system"}], ["abstraction_level", {"type": "ratio", "connects": "model to reality"}], ["documentation", {"type": "key", "translates": "variables"}]], [["represents", ["parameters", "real_system"], false], ["reduces", ["abstraction_level", "complexity"], false], ["interprets", ["documentation", "parameters"], false]])
        self.domain_pairs.append(["map", "model"])

        logger.debug("ConceptStore loaded " + string(self.concepts.len()) + " domains, " + string(self.domain_pairs.len()) + " pairs")
    }
}

/// ── Structure Mapper ───────────────────────────────────────────────────

class StructureMapper {
    fn new(store: ConceptStore) -> StructureMapper {
        let sm = StructureMapper {}
        sm._store = store
        sm.STRUCTURAL_WEIGHT = 0.5
        sm.SYSTEMATICITY_WEIGHT = 0.3
        sm.SURFACE_WEIGHT = 0.2
        sm.HIGHER_ORDER_BONUS = 2.0
        return sm
    }

    fn map_domains(self, source: string, target: string) -> StructureMapping {
        let src_rels = self._store.get_relations(source)
        let tgt_rels = self._store.get_relations(target)
        let src_concepts = self._store.get_concepts(source)
        let tgt_concepts = self._store.get_concepts(target)

        if src_rels.len() == 0 || tgt_rels.len() == 0 {
            return StructureMapping { source_domain: source, target_domain: target, concept_mappings: {}, relation_mappings: [], structural_score: 0.0, surface_score: 0.0, systematicity_score: 0.0, overall_score: 0.0 }
        }

        let concept_mappings: Dict[string, string] = {}
        let relation_mappings: List[List[string]] = []
        let matched = 0.0
        let total_weight = 0.0

        for sr in src_rels {
            let weight = 1.0
            if sr.is_higher_order { weight = self.HIGHER_ORDER_BONUS }
            total_weight += weight
            for tr in tgt_rels {
                if sr.predicate == tr.predicate {
                    relation_mappings.append([sr.predicate + "(" + sr.arguments.join(",") + ")", tr.predicate + "(" + tr.arguments.join(",") + ")"])
                    matched += weight
                    let ai = 0
                    while ai < sr.arguments.len() && ai < tr.arguments.len() {
                        if sr.arguments[ai] not in concept_mappings {
                            concept_mappings[sr.arguments[ai]] = tr.arguments[ai]
                        }
                        ai += 1
                    }
                    break
                }
            }
        }

        let structural = 0.0
        if total_weight > 0 { structural = matched / total_weight }
        let systematicity = self._systematicity(src_rels, tgt_rels, concept_mappings)
        let surface = self._surface_similarity(src_concepts, tgt_concepts, concept_mappings)
        let overall = self.STRUCTURAL_WEIGHT * structural + self.SYSTEMATICITY_WEIGHT * systematicity + self.SURFACE_WEIGHT * surface

        return StructureMapping { source_domain: source, target_domain: target, concept_mappings: concept_mappings, relation_mappings: relation_mappings, structural_score: round(structural, 4), surface_score: round(surface, 4), systematicity_score: round(systematicity, 4), overall_score: round(overall, 4) }
    }

    fn _systematicity(self, src_rels: List[Relation], tgt_rels: List[Relation], concept_map: Dict[string, string]) -> float {
        if concept_map.len() == 0 { return 0.0 }
        let src_predicates: Set[string] = Set.new()
        for r in src_rels { src_predicates.add(r.predicate) }
        let tgt_predicates: Set[string] = Set.new()
        for r in tgt_rels { tgt_predicates.add(r.predicate) }
        let shared = src_predicates.intersection(tgt_predicates)
        if shared.len() == 0 { return 0.0 }
        let mapped_args: Set[string] = Set.from(concept_map.keys())
        let connected = 0
        for r in src_rels {
            if r.predicate in shared {
                if mapped_args.intersection(Set.from(r.arguments)).len() > 0 {
                    connected += 1
                }
            }
        }
        let max_rels = src_rels.len()
        if max_rels == 0 { max_rels = 1 }
        let result = connected / max_rels
        if result > 1.0 { result = 1.0 }
        return result
    }

    fn _surface_similarity(self, src_concepts: List[Concept], tgt_concepts: List[Concept], concept_map: Dict[string, string]) -> float {
        if concept_map.len() == 0 || src_concepts.len() == 0 || tgt_concepts.len() == 0 { return 0.0 }
        let src_by_name: Dict[string, Concept] = {}
        for c in src_concepts { src_by_name[c.name] = c }
        let tgt_by_name: Dict[string, Concept] = {}
        for c in tgt_concepts { tgt_by_name[c.name] = c }
        let total = 0
        let shared = 0.0
        for sc_name, tc_name in concept_map.items() {
            let sc = src_by_name.get(sc_name, None)
            let tc = tgt_by_name.get(tc_name, None)
            if sc == None || tc == None { continue }
            let all_keys = Set.from(sc.attributes.keys()).union(Set.from(tc.attributes.keys()))
            if all_keys.len() == 0 { continue }
            total += all_keys.len()
            for k in all_keys {
                if k in sc.attributes && k in tc.attributes {
                    if sc.attributes[k] == tc.attributes[k] {
                        shared += 1
                    } else {
                        shared += 0.25
                    }
                }
            }
        }
        if total == 0 { return 0.0 }
        return shared / total
    }
}

/// ── NL generation helpers ──────────────────────────────────────────────

let NICE_NAME_RE = re.compile("[_\\-]+")

fn _nice(name: string) -> string { return NICE_NAME_RE.sub(" ", name) }
fn _a_or_an(word: string) -> string {
    if word[0].lower() in "aeiou" { return "an" }
    return "a"
}

fn _build_explanation(mapping: StructureMapping, store: ConceptStore) -> string {
    let src = _nice(mapping.source_domain)
    let tgt = _nice(mapping.target_domain)
    let src_rels = store.get_relations(mapping.source_domain)
    let tgt_rels = store.get_relations(mapping.target_domain)
    let src_by_pred: Dict[string, Relation] = {}
    for r in src_rels { src_by_pred[r.predicate] = r }
    let tgt_by_pred: Dict[string, Relation] = {}
    for r in tgt_rels { tgt_by_pred[r.predicate] = r }
    let shared_preds: List[string] = []
    for p in src_by_pred.keys() {
        if p in tgt_by_pred { shared_preds.append(p) }
    }
    if shared_preds.len() == 0 {
        return src.title() + " shares structural similarity with " + tgt + "."
    }
    let clauses: List[string] = []
    let count = 0
    for pred in shared_preds {
        if count >= 3 { break }
        let sr = src_by_pred[pred]
        let tr = tgt_by_pred[pred]
        let src_subj = src
        if sr.arguments.len() > 0 { src_subj = _nice(sr.arguments[0]) }
        let src_obj = ""
        if sr.arguments.len() > 1 { src_obj = _nice(sr.arguments[1]) }
        let tgt_subj = tgt
        if tr.arguments.len() > 0 { tgt_subj = _nice(tr.arguments[0]) }
        let tgt_obj = ""
        if tr.arguments.len() > 1 { tgt_obj = _nice(tr.arguments[1]) }
        let verb = _nice(pred)
        if src_obj != "" && tgt_obj != "" {
            clauses.append("just as " + src_subj + " " + verb + " " + src_obj + ", " + tgt_subj + " " + verb + " " + tgt_obj)
        } else {
            clauses.append(src_subj + " " + verb + " in the same way " + tgt_subj + " " + verb)
        }
        count += 1
    }
    return src.title() + " is like " + tgt + " — " + clauses.join("; and ") + "."
}

fn _build_inferences(mapping: StructureMapping, store: ConceptStore) -> List[any] {
    let inferences: List[string] = []
    let src_rels = store.get_relations(mapping.source_domain)
    let tgt_rels = store.get_relations(mapping.target_domain)
    let tgt_preds: Set[string] = Set.new()
    for r in tgt_rels { tgt_preds.add(r.predicate) }
    for sr in src_rels {
        if sr.predicate not in tgt_preds {
            let mapped_args: List[string] = []
            for a in sr.arguments {
                mapped_args.append(mapping.concept_mappings.get(a, _nice(a)))
            }
            inferences.append("If " + _nice(mapping.source_domain) + " exhibits '" + _nice(sr.predicate) + "' between " + _nice(sr.arguments[0]) + " and " + _nice(sr.arguments[sr.arguments.len() - 1]) + ", then " + _nice(mapping.target_domain) + " may exhibit an analogous '" + _nice(sr.predicate) + "' between " + _nice(mapped_args[0]) + " and " + _nice(mapped_args[mapped_args.len() - 1]) + ".")
        }
    }
    if inferences.len() == 0 {
        let count = 0
        for sc, tc in mapping.concept_mappings.items() {
            if count >= 2 { break }
            inferences.append("Properties of " + _nice(sc) + " in " + _nice(mapping.source_domain) + " likely have counterparts for " + _nice(tc) + " in " + _nice(mapping.target_domain) + ".")
            count += 1
        }
    }
    return inferences
}

/// ── Analogy Engine ─────────────────────────────────────────────────────

class AnalogyEngine {
    fn new(store: Optional[ConceptStore]) -> AnalogyEngine {
        let ae = AnalogyEngine {}
        if store != None { ae._store = store } else { ae._store = ConceptStore.new() }
        ae._mapper = StructureMapper.new(ae._store)
        ae._cache = {}
        return ae
    }

    fn find_analogy(self, concept: string, target_domain: string) -> AnalogyResult {
        let source_domain = self._domain_of(concept)
        if source_domain == None {
            return AnalogyResult { source: concept, target: target_domain, mapping: None, explanation: "No domain found containing '" + concept + "'.", inferences: [], confidence: 0.0 }
        }
        if target_domain != "" {
            let resolved = self._store.resolve_domain(target_domain)
            if resolved == None { resolved = target_domain }
            return self._build_result(source_domain, resolved)
        }
        let best: Optional[AnalogyResult] = None
        for domain in self._store.domains() {
            if domain == source_domain { continue }
            let result = self._build_result(source_domain, domain)
            if best == None || result.confidence > best.confidence {
                best = result
            }
        }
        if best != None { return best }
        return AnalogyResult { source: concept, target: "none", mapping: None, explanation: "No suitable analogy found.", inferences: [], confidence: 0.0 }
    }

    fn explain_by_analogy(self, concept: string, familiar_domain: string) -> string {
        let source_domain = self._domain_of(concept)
        let target = self._store.resolve_domain(familiar_domain)
        if target == None { target = familiar_domain }
        if source_domain == None { return "Unable to locate '" + concept + "' in the knowledge base." }
        let mapping = self._get_mapping(source_domain, target)
        let src_rels = self._store.get_relations(source_domain)
        let tgt_rels = self._store.get_relations(target)
        let src_by_pred: Dict[string, Relation] = {}
        for r in src_rels { src_by_pred[r.predicate] = r }
        let tgt_by_pred: Dict[string, Relation] = {}
        for r in tgt_rels { tgt_by_pred[r.predicate] = r }
        let shared: List[string] = []
        for p in src_by_pred.keys() {
            if p in tgt_by_pred { shared.append(p) }
        }
        let src_nice = _nice(source_domain)
        let tgt_nice = _nice(target)
        if shared.len() == 0 {
            return "Think of " + src_nice + " as " + _a_or_an(tgt_nice) + " " + tgt_nice + ": both share a similar underlying structure."
        }
        let clauses: List[string] = []
        let count = 0
        for pred in shared {
            if count >= 3 { break }
            let sr = src_by_pred[pred]
            let tr = tgt_by_pred[pred]
            let verb = _nice(pred)
            if sr.arguments.len() >= 2 && tr.arguments.len() >= 2 {
                clauses.append(_nice(sr.arguments[0]) + " " + verb + " " + _nice(sr.arguments[1]) + " in " + src_nice + ", much like " + _nice(tr.arguments[0]) + " " + verb + " " + _nice(tr.arguments[1]) + " in " + tgt_nice)
            } else {
                let s_args: List[string] = []
                for a in sr.arguments { s_args.append(_nice(a)) }
                let t_args: List[string] = []
                for a in tr.arguments { t_args.append(_nice(a)) }
                clauses.append(s_args.join(" and ") + " " + verb + " in " + src_nice + ", much like " + t_args.join(" and ") + " " + verb + " in " + tgt_nice)
            }
            count += 1
        }
        return "Think of " + src_nice + " as " + _a_or_an(tgt_nice) + " " + tgt_nice + ": " + clauses.join("; ") + "."
    }

    fn transfer_inference(self, source: string, source_property: string, target: string) -> string {
        let src_domain = self._domain_of(source)
        let tgt_domain = self._domain_of(target)
        if src_domain == None || tgt_domain == None {
            let missing = source
            if src_domain != None { missing = target }
            return "Cannot resolve '" + missing + "' to a known domain."
        }
        let mapping = self._get_mapping(src_domain, tgt_domain)
        let mapped_target = mapping.concept_mappings.get(source, _nice(target))
        let prop_stem = _stem(source_property)
        let tgt_rels = self._store.get_relations(tgt_domain)
        for tr in tgt_rels {
            if _stem(tr.predicate) == prop_stem {
                let t_args: List[string] = []
                for a in tr.arguments { t_args.append(_nice(a)) }
                return "Since " + _nice(source) + " exhibits '" + _nice(source_property) + "' in " + _nice(src_domain) + ", the analogous property in " + _nice(tgt_domain) + " is '" + _nice(tr.predicate) + "' involving " + t_args.join(" and ") + "."
            }
        }
        let src_rels = self._store.get_relations(src_domain)
        for sr in src_rels {
            if _stem(sr.predicate) == prop_stem {
                let mapped_args: List[string] = []
                for a in sr.arguments { mapped_args.append(_nice(mapping.concept_mappings.get(a, a))) }
                return "Since " + _nice(source) + " exhibits '" + _nice(source_property) + "' in " + _nice(src_domain) + ", we infer that " + _nice(mapped_target) + " may exhibit an analogous relationship involving " + mapped_args.join(" and ") + " in " + _nice(tgt_domain) + "."
            }
        }
        return "Since " + _nice(source) + " has the property '" + _nice(source_property) + "' in " + _nice(src_domain) + ", " + _nice(mapped_target) + " likely has a corresponding property in " + _nice(tgt_domain) + " — but the specific form could not be determined from the current knowledge base."
    }

    fn generate_analogy(self, concept_a: string, concept_b: string) -> AnalogyResult {
        let domain_a = self._domain_of(concept_a)
        let domain_b = self._domain_of(concept_b)
        if domain_a == None && domain_b == None {
            return AnalogyResult { source: concept_a, target: concept_b, mapping: None, explanation: "Neither '" + concept_a + "' nor '" + concept_b + "' could be resolved to a known domain.", inferences: [], confidence: 0.0 }
        }
        if domain_a == None {
            return AnalogyResult { source: concept_a, target: concept_b, mapping: None, explanation: "Could not resolve '" + concept_a + "' to a known domain.", inferences: [], confidence: 0.0 }
        }
        if domain_b == None {
            return AnalogyResult { source: concept_a, target: concept_b, mapping: None, explanation: "Could not resolve '" + concept_b + "' to a known domain.", inferences: [], confidence: 0.0 }
        }
        if domain_a == domain_b {
            return AnalogyResult { source: concept_a, target: concept_b, mapping: None, explanation: "Both '" + concept_a + "' and '" + concept_b + "' belong to the same domain (" + _nice(domain_a) + "); no cross-domain analogy needed.", inferences: [], confidence: 1.0 }
        }
        return self._build_result(domain_a, domain_b)
    }

    fn rate_analogy(self, source: string, target: string) -> float {
        let src_domain = self._store.resolve_domain(source)
        if src_domain == None { src_domain = self._domain_of(source) }
        let tgt_domain = self._store.resolve_domain(target)
        if tgt_domain == None { tgt_domain = self._domain_of(target) }
        if src_domain == None || tgt_domain == None { return 0.0 }
        if src_domain == tgt_domain { return 1.0 }
        let mapping = self._get_mapping(src_domain, tgt_domain)
        return mapping.overall_score
    }

    fn ingest_domain(self, domain: string, concepts: List[Concept], relations: List[Relation]) -> void {
        self._store.add_domain(domain, concepts, relations)
        logger.info("Ingested domain '" + domain + "' with " + string(concepts.len()) + " concepts, " + string(relations.len()) + " relations")
    }

    fn _domain_of(self, concept: string) -> Optional[string] {
        let concept_lower = concept.lower().replace(" ", "_")
        for domain, concepts in self._store.concepts.items() {
            for c in concepts {
                if c.name == concept_lower || c.name == concept { return domain }
            }
        }
        for domain, relations in self._store.relations.items() {
            for r in relations {
                for arg in r.arguments {
                    if arg == concept_lower || arg == concept { return domain }
                }
            }
        }
        for domain, concepts in self._store.concepts.items() {
            let names: List[string] = []
            for c in concepts { names.append(c.name) }
            let match = _fuzzy_match(concept, names, 0.5)
            if match != None { return domain }
        }
        for domain, relations in self._store.relations.items() {
            let all_args: List[string] = []
            for r in relations { all_args.extend(r.arguments) }
            let match = _fuzzy_match(concept, all_args, 0.5)
            if match != None { return domain }
        }
        return self._store.resolve_domain(concept)
    }

    fn _get_mapping(self, source: string, target: string) -> StructureMapping {
        let key = source + "::" + target
        if key not in self._cache {
            self._cache[key] = self._mapper.map_domains(source, target)
        }
        return self._cache[key]
    }

    fn _build_result(self, source: string, target: string) -> AnalogyResult {
        let mapping = self._get_mapping(source, target)
        let explanation = _build_explanation(mapping, self._store)
        let inferences = _build_inferences(mapping, self._store)
        return AnalogyResult { source: source, target: target, mapping: mapping, explanation: explanation, inferences: inferences, confidence: mapping.overall_score }
    }
}

export Concept, Relation, StructureMapping, AnalogyResult
export ConceptStore, StructureMapper, AnalogyEngine
