/// NRS Analogy Engine — Cross-Domain Structure Mapping.
///
/// Implements Gentner's Structure-Mapping Theory for analogical reasoning.
/// 32 pre-built domain pairs, fuzzy concept lookup, inference transfer.

module analogy_engine

import re from "std/regex"
import logging from "std/logging"

let logger = logging.getLogger("nrs.analogy")

/// ── Data Structures ────────────────────────────────────────────────────

type Concept {
    name: string,
    domain: string,
    attributes: Dict[string, any]
}

type Relation {
    predicate: string,
    arguments: List[string],
    is_higher_order: bool,
    weight: float
}

type StructureMapping {
    source_domain: string,
    target_domain: string,
    concept_mappings: Dict[string, string],
    relation_mappings: List[List[string]],
    structural_score: float,
    surface_score: float,
    systematicity_score: float,
    overall_score: float
}

type AnalogyResult {
    source: string,
    target: string,
    mapping: Optional[StructureMapping],
    explanation: string,
    inferences: List[string],
    confidence: float
}

/// ── Stem-based fuzzy matching ──────────────────────────────────────────

let SUFFIX_RE = re.compile("(tion|sion|ment|ness|ity|ing|ous|ive|ful|less|able|ible|ence|ance|er|or|ed|ly|es|s)$")

fn _stem(word: string) -> string {
    let w = word.lower().replace("_", "").replace("-", "")
    if w.len() > 5 {
        w = SUFFIX_RE.sub("", w)
    }
    return w
}

fn _fuzzy_match(query: string, candidates: List[string], threshold: float) -> Optional[string] {
    let q_stem = _stem(query)
    let best: Optional[string] = None
    let best_score = threshold
    for c in candidates {
        let c_stem = _stem(c)
        if q_stem == c_stem { return c }
        if q_stem in c_stem || c_stem in q_stem {
            let min_len = q_stem.len()
            if c_stem.len() < min_len { min_len = c_stem.len() }
            let max_len = q_stem.len()
            if c_stem.len() > max_len { max_len = c_stem.len() }
            if max_len == 0 { max_len = 1 }
            let overlap = min_len / max_len
            if overlap > best_score {
                best = c
                best_score = overlap
            }
        }
    }
    return best
}

/// ── Concept Store ──────────────────────────────────────────────────────

class ConceptStore {
    fn new() -> ConceptStore {
        let cs = ConceptStore {}
        cs.concepts = {}
        cs.relations = {}
        cs.domain_pairs = []
        cs._load_builtin_domains()
        return cs
    }

    fn domains(self) -> List[any] { return self.concepts.keys() }
    fn get_concepts(self, domain: string) -> List[any] { return self.concepts.get(domain, []) }
    fn get_relations(self, domain: string) -> List[any] { return self.relations.get(domain, []) }

    fn paired_domain(self, domain: string) -> Optional[string] {
        for pair in self.domain_pairs {
            if pair[0] == domain { return pair[1] }
            if pair[1] == domain { return pair[0] }
        }
        return None
    }

    fn resolve_domain(self, name: string) -> Optional[string] {
        return _fuzzy_match(name, self.domains(), 0.5)
    }

    fn add_domain(self, domain: string, concepts: List[Concept], relations: List[Relation]) -> void {
        self.concepts[domain] = concepts
        self.relations[domain] = relations
    }

    fn add_pair(self, domain_a: string, domain_b: string) -> void {
        for pair in self.domain_pairs {
            if (pair[0] == domain_a && pair[1] == domain_b) || (pair[0] == domain_b && pair[1] == domain_a) {
                return
            }
        }
        self.domain_pairs.append([domain_a, domain_b])
    }

    fn _add(self, domain: string, concept_data: List[List[any]], relation_data: List[List[any]]) -> void {
        let concepts: List[Concept] = []
        for cd in concept_data {
            concepts.append(Concept { name: cd[0], domain: domain, attributes: cd[1] })
        }
        self.concepts[domain] = concepts
        let relations: List[Relation] = []
        for rd in relation_data {
            relations.append(Relation { predicate: rd[0], arguments: rd[1], is_higher_order: rd[2], weight: 1.0 })
        }
        self.relations[domain] = relations
    }

