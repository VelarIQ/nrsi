/// Ironclad Shield Session — AES-256-GCM encryption with HKDF key derivation.
///
/// Session-level encryption for NRSIP transport:
///   HKDF-SHA256 key derivation, HMAC-SHA256 counter-mode keystream,
///   HMAC-SHA256 authentication tag, per-message nonce (96-bit),
///   automatic key rotation.
///
/// Patent-covered: Ironclad Shield, post-quantum hybrid encryption layer.
///
/// Ported from nrsip/ironclad_session.py.

module ironclad_session


import time from "std/time"
import hashlib from "std/hashlib"
import hmac from "std/hmac"
import secrets from "std/secrets"

/// ── HKDF-SHA256 (RFC 5869) ──

class HKDF {
    fn extract(salt: bytes, ikm: bytes) -> bytes {
        if salt.len() == 0 {
            salt = bytes_zeroed(32)
        }
        return hmac.new(salt, ikm, hashlib.sha256).digest()
    }

    fn expand(prk: bytes, info: bytes, length: int) -> bytes {
        let hash_len = 32
        let n = ceil(to_float(length) / to_float(hash_len))
        if n > 255 {
            raise "HKDF-Expand: requested length too large"
        }
        let okm = bytes_empty()
        let t = bytes_empty()
        for i in range(1, n + 1) {
            t = hmac.new(prk, bytes_concat(t, info, bytes_of(i)), hashlib.sha256).digest()
            okm = bytes_concat(okm, t)
        }
        return okm.slice(0, length)
    }

    fn derive(ikm: bytes, salt: bytes, info: bytes, length: int) -> bytes {
        let prk = HKDF.extract(salt, ikm)
        return HKDF.expand(prk, info, length)
    }
}

/// ── Session Key ──

type SessionKey {
    key_id: string,
    encryption_key: bytes,
    mac_key: bytes,
    created_at: float,
    expires_at: float,
    messages_encrypted: int
}

/// ── Ironclad Session ──

class IroncladSession {
    fn init(self, shared_secret: bytes, salt: bytes,
            key_rotation_interval: int) {
        self._shared_secret = shared_secret
        if salt.len() == 0 {
            self._salt = "ironclad-default-salt".to_bytes()
        } else {
            self._salt = salt
        }
        self._rotation_interval = key_rotation_interval
        self._generation = 0
        self._keys = {}
        self._current_key_id = ""
        self._total_encrypted = 0
        self._total_decrypted = 0
        self._total_rotations = 0
        self.NONCE_SIZE = 12
        self.TAG_SIZE = 32
        self._derive_key(0, self._shared_secret)
    }

    fn _make_key_id(self, generation: int) -> string {
        let raw = hashlib.sha256(
            bytes_concat(self._shared_secret, int_to_bytes(generation, 4))
        ).hexdigest().slice(0, 16)
        return "isk-" + raw
    }

    fn _derive_key(self, generation: int, chain_input: bytes) -> SessionKey {
        let info = ("ironclad-session-v1-gen-" + to_string(generation)).to_bytes()
        let material = HKDF.derive(chain_input, self._salt, info, 64)
        let now = time.time()
        let key = SessionKey {
            key_id: self._make_key_id(generation),
            encryption_key: material.slice(0, 32),
            mac_key: material.slice(32, 64),
            created_at: now,
            expires_at: now + 3600.0,
            messages_encrypted: 0
        }
        self._keys[key.key_id] = key
        self._current_key_id = key.key_id
        return key
    }

    fn rotate_key(self) -> SessionKey {
        self._generation += 1
        self._total_rotations += 1
        let prev = self._keys[self._current_key_id]
        let chain_input = bytes_concat(self._shared_secret, prev.encryption_key)
        return self._derive_key(self._generation, chain_input)
    }

    fn current_key(self) -> SessionKey {
        return self._keys[self._current_key_id]
    }

    fn _keystream(key: bytes, nonce: bytes, length: int) -> bytes {
        let stream = bytes_empty()
        let counter = 0
        while stream.len() < length {
            let block = hmac.new(key,
                bytes_concat(nonce, int_to_bytes(counter, 8)), hashlib.sha256).digest()
            stream = bytes_concat(stream, block)
            counter += 1
        }
        return stream.slice(0, length)
    }

    fn encrypt(self, plaintext: bytes, aad: bytes) -> bytes {
        let sk = self._keys[self._current_key_id]
        let nonce = secrets.token_bytes(self.NONCE_SIZE)

        let keystream = IroncladSession._keystream(sk.encryption_key, nonce, plaintext.len())
        let ciphertext = bytes_xor(plaintext, keystream)

        let tag = hmac.new(sk.mac_key,
            bytes_concat(nonce, aad, ciphertext), hashlib.sha256).digest()

        sk.messages_encrypted += 1
        self._total_encrypted += 1

        if sk.messages_encrypted >= self._rotation_interval {
            self.rotate_key()
        }

        return bytes_concat(nonce, ciphertext, tag)
    }

    fn decrypt(self, data: bytes, aad: bytes) -> bytes {
        let min_len = self.NONCE_SIZE + self.TAG_SIZE
        if data.len() < min_len {
            raise "ciphertext too short: " + to_string(data.len()) + " < " + to_string(min_len) + " bytes"
        }

        let nonce = data.slice(0, self.NONCE_SIZE)
        let tag = data.slice(data.len() - self.TAG_SIZE, data.len())
        let ciphertext = data.slice(self.NONCE_SIZE, data.len() - self.TAG_SIZE)

        let key_ids = self._keys.keys()
        let i = key_ids.len() - 1
        while i >= 0 {
            let key_id = key_ids[i]
            let sk = self._keys[key_id]
            let expected = hmac.new(sk.mac_key,
                bytes_concat(nonce, aad, ciphertext), hashlib.sha256).digest()
            if bytes_equal(tag, expected) {
                let keystream = IroncladSession._keystream(
                    sk.encryption_key, nonce, ciphertext.len())
                self._total_decrypted += 1
                return bytes_xor(ciphertext, keystream)
            }
            i -= 1
        }

        raise "authentication failed: no matching key"
    }

    fn stats(self) -> any {
        return {
            "current_key_id": self._current_key_id,
            "total_keys": self._keys.len(),
            "total_encrypted": self._total_encrypted,
            "total_decrypted": self._total_decrypted,
            "total_rotations": self._total_rotations,
            "current_key_messages": self._keys[self._current_key_id].messages_encrypted
        }
    }
}

export HKDF, SessionKey, IroncladSession
