/// NRS Goal Decomposition Planner — Multi-Step Reasoning Through Planning.
///
/// Decomposes complex questions into sub-questions, plans multi-step
/// reasoning chains, evaluates alternative approaches, tracks progress,
/// and detects when sub-answers contradict or support each other.
///
/// Operates above the causal-graph GoalPlanner in reasoning_planning:
/// that module navigates edges in a CausalGraph; this module decomposes
/// natural-language queries into structured HTN plans.

module planner

import logging from "std/logging"
import math from "std/math"
import re from "std/regex"
import time from "std/time"
import uuid from "std/uuid"

let logger = logging.getLogger("nrs.planner")

/// ── Identifiers ────────────────────────────────────────────────────────

fn _uid(prefix: string) -> string {
    return prefix + uuid.uuid4_hex()[0:12]
}

fn _now() -> float {
    return time.time()
}

/// ── Goal Types ─────────────────────────────────────────────────────────

enum GoalType {
    ANSWER,
    PROVE,
    COMPARE,
    EXPLAIN,
    LIST,
    COMPUTE,
    EVALUATE,
    TEMPORAL
}

fn goal_type_value(gt: GoalType) -> string {
    if gt == GoalType.ANSWER { return "answer" }
    if gt == GoalType.PROVE { return "prove" }
    if gt == GoalType.COMPARE { return "compare" }
    if gt == GoalType.EXPLAIN { return "explain" }
    if gt == GoalType.LIST { return "list" }
    if gt == GoalType.COMPUTE { return "compute" }
    if gt == GoalType.EVALUATE { return "evaluate" }
    if gt == GoalType.TEMPORAL { return "temporal" }
    return "answer"
}

enum GoalStatus {
    PENDING,
    ACTIVE,
    COMPLETED,
    FAILED,
    BLOCKED
}

fn goal_status_value(gs: GoalStatus) -> string {
    if gs == GoalStatus.PENDING { return "pending" }
    if gs == GoalStatus.ACTIVE { return "active" }
    if gs == GoalStatus.COMPLETED { return "completed" }
    if gs == GoalStatus.FAILED { return "failed" }
    if gs == GoalStatus.BLOCKED { return "blocked" }
    return "pending"
}

enum StepAction {
    RETRIEVE,
    COMPUTE,
    INFER,
    COMPARE,
    SYNTHESIZE,
    VERIFY,
    DECOMPOSE,
    RANK,
    ENUMERATE
}

fn step_action_value(sa: StepAction) -> string {
    if sa == StepAction.RETRIEVE { return "retrieve" }
    if sa == StepAction.COMPUTE { return "compute" }
    if sa == StepAction.INFER { return "infer" }
    if sa == StepAction.COMPARE { return "compare" }
    if sa == StepAction.SYNTHESIZE { return "synthesize" }
    if sa == StepAction.VERIFY { return "verify" }
    if sa == StepAction.DECOMPOSE { return "decompose" }
    if sa == StepAction.RANK { return "rank" }
    if sa == StepAction.ENUMERATE { return "enumerate" }
    return "retrieve"
}

fn step_action_from_name(name: string) -> StepAction {
    let n = name.upper()
    if n == "RETRIEVE" { return StepAction.RETRIEVE }
    if n == "COMPUTE" { return StepAction.COMPUTE }
    if n == "INFER" { return StepAction.INFER }
    if n == "COMPARE" { return StepAction.COMPARE }
    if n == "SYNTHESIZE" { return StepAction.SYNTHESIZE }
    if n == "VERIFY" { return StepAction.VERIFY }
    if n == "DECOMPOSE" { return StepAction.DECOMPOSE }
    if n == "RANK" { return StepAction.RANK }
    if n == "ENUMERATE" { return StepAction.ENUMERATE }
    return StepAction.RETRIEVE
}

/// ── Data Objects ───────────────────────────────────────────────────────

class Goal {
    fn new(description: string, goal_type: GoalType) -> Goal {
        let g = Goal {}
        g.description = description
        g.goal_type = goal_type
        g.goal_id = _uid("goal-")
        g.priority = 1.0
        g.parent = None
        g.constraints = {}
        g.status = GoalStatus.PENDING
        g.result = None
        g.created_at = _now()
        return g
    }

    fn to_dict(self) -> Dict[string, any] {
        return {
            "goal_id": self.goal_id,
            "description": self.description,
            "goal_type": goal_type_value(self.goal_type),
            "priority": self.priority,
            "parent": self.parent,
            "constraints": self.constraints,
            "status": goal_status_value(self.status),
            "result": self.result,
            "created_at": self.created_at
        }
    }
}


class PlanStep {
    fn new(action: StepAction, description: string) -> PlanStep {
        let s = PlanStep {}
        s.action = action
        s.description = description
        s.step_id = _uid("step-")
        s.inputs = []
        s.status = GoalStatus.PENDING
        s.result = None
        s.confidence = 0.0
        s.error = None
        s.started_at = None
        s.finished_at = None
        return s
    }

    fn elapsed_ms(self) -> float {
        if self.started_at == None { return 0.0 }
        let end = self.finished_at
        if end == None { end = _now() }
        return (end - self.started_at) * 1000
    }

    fn to_dict(self) -> Dict[string, any] {
        return {
            "step_id": self.step_id,
            "action": step_action_value(self.action),
            "description": self.description,
            "inputs": self.inputs,
            "status": goal_status_value(self.status),
            "result": self.result,
            "confidence": self.confidence,
            "error": self.error,
            "elapsed_ms": self.elapsed_ms()
        }
    }
}


class HTNPlan {
    fn new() -> HTNPlan {
        let p = HTNPlan {}
        p.plan_id = _uid("plan-")
        p.goal = None
        p.steps = []
        p.estimated_confidence = 0.0
        p.actual_confidence = 0.0
        p.status = GoalStatus.PENDING
        p.decomposition_type = ""
        p.synthesis = None
        p.created_at = _now()
        p.finished_at = None
        return p
    }

    fn completed_steps(self) -> int {
        let count = 0
        for s in self.steps {
            if s.status == GoalStatus.COMPLETED { count += 1 }
        }
        return count
    }

    fn progress(self) -> float {
        if self.steps.len() == 0 { return 0.0 }
        return self.completed_steps() / self.steps.len()
    }

    fn elapsed_ms(self) -> float {
        let end = self.finished_at
        if end == None { end = _now() }
        return (end - self.created_at) * 1000
    }

    fn to_dict(self) -> Dict[string, any] {
        let step_dicts: List[Dict[string, any]] = []
        for s in self.steps { step_dicts.append(s.to_dict()) }
        let goal_dict = None
        if self.goal != None { goal_dict = self.goal.to_dict() }
        return {
            "plan_id": self.plan_id,
            "goal": goal_dict,
            "steps": step_dicts,
            "estimated_confidence": self.estimated_confidence,
            "actual_confidence": self.actual_confidence,
            "status": goal_status_value(self.status),
            "decomposition_type": self.decomposition_type,
            "synthesis": self.synthesis,
            "progress": self.progress(),
            "elapsed_ms": self.elapsed_ms()
        }
    }
}


