/// NRSI — Common-Sense Bootstrapper.
///
/// Generate obvious relations from templates, property inheritance,
/// transitivity closure, default reasoning, and spatial/physical common sense.
/// All transformer-free.

module reasoning_commonsense


import time from "std/time"
from "reasoning_graph" import CausalGraph, GraphEdge, RelationType

