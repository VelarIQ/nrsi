let _PROPERTY_INHERITANCE: Dict[string, Dict[string, bool]] = {
    "animal": {"alive": true, "needs_food": true, "needs_water": true, "can_move": true},
    "mammal": {"warm_blooded": true, "has_hair": true, "breathes_air": true},
    "bird": {"has_feathers": true, "lays_eggs": true, "has_wings": true},
    "fish": {"lives_in_water": true, "has_gills": true, "cold_blooded": true},
