    "vehicle": {"needs_energy": true, "transports": true, "human_made": true},
    "gas": {"fills_container": true, "compressible": true, "has_no_fixed_shape": true}
}

/// ---------- Causal Common-Sense Templates ----------

let _CAUSAL_TEMPLATES: List[Tuple[string, string, RelationType, float]] = [
    ("fire", "heat", RelationType.CAUSES, 0.95),
    ("fire", "light", RelationType.CAUSES, 0.9),
    ("fire", "smoke", RelationType.PRODUCES, 0.85),
    ("rain", "wetness", RelationType.CAUSES, 0.95),
    ("rain", "flood", RelationType.CAUSES, 0.6),
    ("sun", "light", RelationType.PRODUCES, 0.95),
    ("sun", "heat", RelationType.PRODUCES, 0.9),
    ("gravity", "falling", RelationType.CAUSES, 0.95),
    ("ice", "cold", RelationType.CORRELATES, 0.9),
    ("exercise", "fitness", RelationType.CAUSES, 0.8),
    ("exercise", "fatigue", RelationType.CAUSES, 0.7),
    ("sleep", "rest", RelationType.CAUSES, 0.9),
    ("food", "energy", RelationType.PRODUCES, 0.85),
    ("water", "life", RelationType.ENABLES, 0.95),
    ("oxygen", "breathing", RelationType.ENABLES, 0.95),
    ("electricity", "light", RelationType.ENABLES, 0.85),
    ("education", "knowledge", RelationType.CAUSES, 0.8),
    ("wind", "erosion", RelationType.CAUSES, 0.7),
    ("pollution", "disease", RelationType.CAUSES, 0.7),
    ("vaccination", "immunity", RelationType.CAUSES, 0.85),
    ("deforestation", "habitat loss", RelationType.CAUSES, 0.85),
    ("overfishing", "species decline", RelationType.CAUSES, 0.8),
    ("drought", "crop failure", RelationType.CAUSES, 0.8),
    ("earthquake", "destruction", RelationType.CAUSES, 0.85),
    ("photosynthesis", "glucose", RelationType.PRODUCES, 0.9),
    ("photosynthesis", "oxygen", RelationType.PRODUCES, 0.9),
    ("evaporation", "cloud formation", RelationType.CAUSES, 0.8),
    ("condensation", "rain", RelationType.CAUSES, 0.85),
    ("freezing", "ice", RelationType.PRODUCES, 0.95),
    ("melting", "liquid", RelationType.PRODUCES, 0.95),
    ("friction", "heat", RelationType.PRODUCES, 0.85),
    ("pressure", "compression", RelationType.CAUSES, 0.8),
    ("aging", "weakness", RelationType.CAUSES, 0.6),
    ("stress", "anxiety", RelationType.CAUSES, 0.7),
    ("cooperation", "success", RelationType.ENABLES, 0.7),
    ("practice", "skill", RelationType.CAUSES, 0.8),
    ("hunger", "eating", RelationType.CAUSES, 0.85),
