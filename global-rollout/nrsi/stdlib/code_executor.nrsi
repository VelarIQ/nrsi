/// NRS Sandboxed Code Executor — Actual Computation for Intelligence.
///
/// Math solving, unit conversions, sandboxed execution with security layers,
/// static analysis, timeout, and output truncation.

module code_executor

import re from "std/regex"
import math from "std/math"
import time from "std/time"
import logging from "std/logging"

let logger = logging.getLogger("nrs.code-executor")

/// ── Data Structures ────────────────────────────────────────────────────

type ExecutionResult {
    success: bool,
    output: any,
    stdout: string,
    error: string,
    execution_time_ms: float
}

fn execution_result_to_dict(r: ExecutionResult) -> Dict[string, any] {
    let out_repr = None
    if r.output != None {
        out_repr = repr(r.output)
    }
    let stdout_val = ""
    if r.stdout != "" {
        stdout_val = r.stdout[0:2000]
    }
    return {
        "success": r.success,
        "output": out_repr,
        "stdout": stdout_val,
        "error": r.error,
        "execution_time_ms": r.execution_time_ms
    }
}

/// ── Sandbox Definitions ────────────────────────────────────────────────

let SAFE_MODULES: Set[string] = Set.of(
    "math", "statistics", "fractions", "decimal",
    "collections", "itertools", "functools", "operator",
    "datetime", "json", "re", "random"
)

let SAFE_BUILTIN_NAMES: Set[string] = Set.of(
    "abs", "all", "any", "bin", "bool", "bytes", "bytearray",
    "chr", "complex", "dict", "divmod", "enumerate", "filter",
    "float", "format", "frozenset", "hash", "hex", "int",
    "isinstance", "issubclass", "iter", "len", "list", "map",
    "max", "memoryview", "min", "next", "oct", "ord", "pow",
    "print", "range", "repr", "reversed", "round", "set",
    "slice", "sorted", "str", "sum", "tuple", "type", "zip"
)

let HARD_FORBIDDEN: List[string] = [
    "__(?:subclasses|bases|mro|globals|builtins|import|code|func|loader|spec|qualname)__",
    "\\bos\\b\\s*\\.\\s*(?:system|popen|exec|fork|kill|remove|unlink|rmdir|rename|mkdir|chdir|getcwd|environ|path|listdir|walk|scandir|getenv|putenv)",
    "\\bsubprocess\\b",
    "\\bsocket\\b",
    "\\bshutil\\b",
    "\\bpathlib\\b",
    "\\bctypes\\b",
    "\\bsignal\\b",
    "\\bimportlib\\b",
    "\\b(?:open|file)\\s*\\(",
    "\\bsys\\b\\s*\\.\\s*(?:exit|modules|path|stdin|stdout|stderr|_getframe|settrace|setprofile)",
    "\\b(?:eval|exec|compile|execfile)\\s*\\(",
    "\\b(?:getattr|setattr|delattr)\\s*\\(",
    "\\b(?:globals|locals|vars)\\s*\\(\\s*\\)",
    "\\bbreakpoint\\s*\\(",
    "\\binput\\s*\\("
]

fn _make_restricted_import() -> fn {
    fn _restricted_import(name: string) -> any {
        if name not in SAFE_MODULES {
            raise ImportError("Import of '" + name + "' is not allowed in sandbox")
        }
        return __real_import__(name)
    }
    return _restricted_import
}

fn _build_safe_builtins() -> Dict[string, any] {
    let safe: Dict[string, any] = {}
    for name in SAFE_BUILTIN_NAMES {
        let obj = builtin_get(name)
        if obj != None {
            safe[name] = obj
        }
    }
    safe["__import__"] = _make_restricted_import()
    safe["__build_class__"] = builtin_get("__build_class__")
    safe["True"] = true
    safe["False"] = false
    safe["None"] = None
    safe["ArithmeticError"] = ArithmeticError
    safe["ZeroDivisionError"] = ZeroDivisionError
    safe["ValueError"] = ValueError
    safe["TypeError"] = TypeError
    safe["KeyError"] = KeyError
    safe["IndexError"] = IndexError
    safe["AttributeError"] = AttributeError
    safe["RuntimeError"] = RuntimeError
    safe["OverflowError"] = OverflowError
    safe["StopIteration"] = StopIteration
    safe["Exception"] = Exception
    return safe
}

/// ── Code Executor ──────────────────────────────────────────────────────

class CodeExecutor {
    /// Sandboxed code execution with static analysis, restricted builtins,
    /// restricted imports, timeout via threading, and output truncation.

    fn __init__(self, timeout_seconds: float = 5.0, max_output_chars: int = 10000) {
        self._timeout = timeout_seconds
        self._max_output = max_output_chars
        self._total_executions = 0
        self._total_successes = 0
        self._total_failures = 0
        self._total_timeouts = 0
    }

    fn execute(self, code: string) -> ExecutionResult {
        let t0 = time.monotonic()
        self._total_executions += 1

        let violation = _static_check(code)
        if violation != None {
            self._total_failures += 1
            return ExecutionResult {
                success: false, output: None, stdout: "",
                error: "Security violation: " + violation,
                execution_time_ms: (time.monotonic() - t0) * 1000
            }
        }

        let sandbox_globals = _build_sandbox()
        let stdout_buf = StringIO.new()
        let holder: Dict[string, any] = {"value": None, "error": None}

        try {
            let result_val = sandbox_exec(code, sandbox_globals, stdout_buf, self._timeout)
            holder["value"] = result_val
        } catch(timeout_err) {
            if timeout_err is TimeoutError {
                self._total_timeouts += 1
                self._total_failures += 1
                return ExecutionResult {
                    success: false, output: None, stdout: "",
                    error: "Execution timed out after " + string(self._timeout) + "s",
                    execution_time_ms: (time.monotonic() - t0) * 1000
                }
            }
            holder["error"] = type_name(timeout_err) + ": " + string(timeout_err)
        }

        let elapsed_ms = (time.monotonic() - t0) * 1000
        let captured = stdout_buf.getvalue()
        if captured.len() > self._max_output {
            captured = captured[0:self._max_output] + "\n... [truncated]"
        }

        if holder["error"] != None {
            self._total_failures += 1
            return ExecutionResult {
                success: false, output: None,
                stdout: captured, error: holder["error"],
                execution_time_ms: elapsed_ms
            }
        }

        self._total_successes += 1

        let output = holder["value"]
        if output == None && captured.strip() != "" {
            let last_line = captured.strip().rsplit("\n", 1)[-1]
            try {
                if "." in last_line {
                    output = float(last_line)
                } else {
                    output = int(last_line)
                }
            } catch(e) {
                output = last_line
            }
        }

        return ExecutionResult {
            success: true, output: output,
            stdout: captured, error: "",
            execution_time_ms: elapsed_ms
        }
    }

    fn stats(self) -> Dict[string, any] {
        return {
            "total_executions": self._total_executions,
            "successes": self._total_successes,
            "failures": self._total_failures,
            "timeouts": self._total_timeouts,
            "success_rate": self._total_successes / max(self._total_executions, 1)
        }
    }
}

fn _static_check(code: string) -> Optional[string] {
    for pattern in HARD_FORBIDDEN {
        let m = re.search(pattern, code)
        if m != None {
            return "Forbidden pattern: " + m.group()
        }
    }
    return None
}

fn _build_sandbox() -> Dict[string, any] {
    let sandbox: Dict[string, any] = {"__builtins__": _build_safe_builtins()}
    for mod_name in SAFE_MODULES {
        try {
            sandbox[mod_name] = __real_import__(mod_name)
        } catch(e) {
            pass
        }
    }
    return sandbox
}

