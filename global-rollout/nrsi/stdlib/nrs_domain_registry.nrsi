/// NRS Domain Registry — Single Source of Truth for Domain Knowledge Routing.
///
/// Every domain (telecom, finance, healthcare, legal, etc.) is defined here
/// with its keyword signals, lobe affinities, knowledge pack paths, and
/// confidence profiles.  All other modules (router, orchestration,
/// nervous_system, signal_compression) import from this registry instead
/// of maintaining their own scattered keyword lists.

module nrs_domain_registry

import logging from "std/logging"

let _log = logging.getLogger("nrs.domain-registry")

/// ── Domain Profile ───────────────────────────────────────────────────

type DomainProfile {
    name: string,
    display_name: string,
    keywords: List[string],
    lobe_affinities: Dict[string, float],
    knowledge_pack_paths: List[string],
    confidence_floor: float,
    parent_domain: Optional[string]
}

