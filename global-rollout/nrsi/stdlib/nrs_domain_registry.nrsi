/// ── Detection and Lookup ─────────────────────────────────────────────

fn detect_domain(query: string) -> DomainProfile {
    let query_lower = query.lower()
    let best_domain = "general"
    let best_score = 0

    for domain_name in DOMAINS {
        let profile = DOMAINS[domain_name]
        if domain_name == "general" { continue }

        let score = 0
        for kw in profile.keywords {
            if kw in query_lower {
                score = score + 1
                if len(kw) > 5 { score = score + 1 }
            }
        }

        if score > best_score {
            best_score = score
            best_domain = domain_name
        }
    }

    return DOMAINS[best_domain]
}

fn get_domain(name: string) -> Optional[DomainProfile] {
    return DOMAINS.get(name, nil)
}

fn get_lobe_weights(domain: string) -> Dict[string, float] {
    let profile = DOMAINS.get(domain, nil)
    if profile == nil {
        return DOMAINS["general"].lobe_affinities
    }
    return profile.lobe_affinities
}

fn get_knowledge_paths(domain: string) -> List[string] {
    let profile = DOMAINS.get(domain, nil)
    if profile == nil { return [] }
    return profile.knowledge_pack_paths
}

fn get_confidence_floor(domain: string) -> float {
    let profile = DOMAINS.get(domain, nil)
    if profile == nil { return 0.70 }
    return profile.confidence_floor
}

fn all_domains() -> List[string] {
    return list(DOMAINS.keys())
}

fn all_keywords_for_domain(domain: string) -> List[string] {
    let profile = DOMAINS.get(domain, nil)
    if profile == nil { return [] }
    return profile.keywords
}

/// ── Exports ──────────────────────────────────────────────────────────

export DomainProfile, DOMAINS
export detect_domain, get_domain, get_lobe_weights, get_knowledge_paths
export get_confidence_floor, all_domains, all_keywords_for_domain
