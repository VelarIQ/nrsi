                    let title = article.get("title", "")
                    let url = article.get("url", "")
                    let source_name = article.get("domain", "")
                    let date = article.get("seendate", "")[0:10]
                    let lang = article.get("language", "")
                    let snippet = "[" + source_name + ", " + date + "] " + title + ". Language: " + lang
                    results.append(new_search_result(
                        title[0:120], url, snippet[0:500], "gdelt"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("GDELT search failed: " + str(e))
            return []
        }
    }

    fn _wikinews_search(self, query: string, count: int) -> List[any] {
        try {
            let wiki_ua = "PRISM-NRS/2.0 (https://velariq.ai; team@velariq.ai)"
            let wc = httpx.Client(timeout: SEARCH_TIMEOUT, headers: {"User-Agent": wiki_ua})
            try {
                let sr_limit = count
                if sr_limit > 10 { sr_limit = 10 }
                let resp = wc.get("https://en.wikinews.org/w/api.php", params: {
                    "action": "query", "list": "search", "srsearch": query,
                    "format": "json", "srlimit": sr_limit, "utf8": "1"
                })
                if resp.status_code != 200 {
                    wc.close()
                    return []
                }
                let results = []
                let items = resp.json().get("query", {}).get("search", [])
                let idx = 0
                for item in items {
                    if idx >= count { break }
                    let title = item.get("title", "")
                    let snippet = strip_html_tags(item.get("snippet", "")).strip()
                    let url = "https://en.wikinews.org/wiki/" + title.replace(" ", "_")
                    if title != "" {
                        results.append(new_search_result(title, url, snippet[0:500], "wikinews"))
                    }
                    idx += 1
                }
                wc.close()
                return results
            } catch(inner_err) {
                wc.close()
                return []
            }
        } catch(e) {
            logging.debug("Wikinews search failed: " + str(e))
            return []
        }
    }

    /// ── Domain-Aware Router ────────────────────────────────────────────

    fn _dispatch_source(self, src_name: string, query: string, per_source: int) -> List[any] {
        if src_name == "pubmed" { return self._pubmed_search(query, per_source) }
        if src_name == "openfda" { return self._openfda_search(query, per_source) }
        if src_name == "clinicaltrials" { return self._clinicaltrials_search(query, per_source) }
        if src_name == "arxiv" { return self._arxiv_search(query, per_source) }
        if src_name == "semantic_scholar" { return self._semantic_scholar_search(query, per_source) }
        if src_name == "oeis" { return self._oeis_search(query, per_source) }
        if src_name == "courtlistener" { return self._courtlistener_search(query, per_source) }
        if src_name == "congress" { return self._congress_search(query, per_source) }
        if src_name == "fred" { return self._fred_search(query, per_source) }
        if src_name == "world_bank" { return self._world_bank_search(query, per_source) }
        if src_name == "geonames" { return self._geonames_search(query, per_source) }
        if src_name == "wikidata" { return self._wikidata_search(query, per_source) }
        if src_name == "stackexchange" { return self._stackexchange_search(query, per_source) }
        if src_name == "sec_edgar" { return self._sec_edgar_search(query, per_source) }
        if src_name == "newsapi" { return self._newsapi_search(query, per_source) }
        if src_name == "wolfram" { return self._wolfram_search(query, per_source) }
        if src_name == "wikipedia" { return self._wikipedia_search(query, per_source) }
        if src_name == "ddg_api" { return self._ddg_api_search(query, per_source) }
        if src_name == "github" { return self._github_search(query, per_source) }
        if src_name == "nominatim" { return self._nominatim_search(query, per_source) }
        if src_name == "gdelt" { return self._gdelt_search(query, per_source) }
        if src_name == "wikinews" { return self._wikinews_search(query, per_source) }
        return []
    }

    fn domain_search(self, query: string, domain: string, count: int) -> List[any] {
        let detected = domain
        if detected == "" {
            detected = detect_query_domain(query)
        }
        let source_names = DOMAIN_SOURCE_MAP.get(detected, DOMAIN_SOURCE_MAP["general"])

        let per_source = count / len(source_names)
        if per_source < 2 { per_source = 2 }

        let all_results = []
        for src_name in source_names {
            let batch = self._dispatch_source(src_name, query, per_source)
            for r in batch {
                all_results.append(r)
            }
        }

        let seen = {}
        let deduped = []
        for r in all_results {
            let key = r.snippet[0:80].lower()
            if key not in seen {
                seen[key] = true
                deduped.append(r)
            }
        }

        return deduped[0:count]
    }

    /// ── Crawl & Text Extraction ────────────────────────────────────────

    fn crawl(self, url: string) -> Optional[string] {
        self._crawl_count += 1
        let client = self._get_client()
        try {
            let resp = client.get(url, timeout: CRAWL_TIMEOUT)
            resp.raise_for_status()
            let content_type = resp.headers.get("content-type", "")
            if "text/html" not in content_type and "text/plain" not in content_type {
                return None
            }
            let raw = resp.text[0:MAX_CRAWL_BYTES]
            return self._extract_text(raw)
        } catch(e) {
            logging.warning("Crawl failed for " + url + ": " + str(e))
            self._failures += 1
            return None
        }
    }

    fn _extract_text(self, html: string) -> string {
        let text = html
        text = re.sub("<script[^>]*>.*?</script>", "", text, flags: re.DOTALL)
        text = re.sub("<style[^>]*>.*?</style>", "", text, flags: re.DOTALL)
        text = re.sub("<[^>]+>", " ", text)
        text = re.sub("\\s+", " ", text).strip()

        let lines = []
        for line in text.split("\n") {
            let stripped = line.strip()
            if len(stripped) > 20 {
                lines.append(stripped)
            }
        }
        return "\n".join(lines[0:100])
    }

    /// ── Full Fact Retrieval Pipeline ───────────────────────────────────

    fn retrieve_facts(self, query: string, max_facts: int, domain_hint: string) -> List[any] {
        let detected_domain = domain_hint
        if detected_domain == "" {
            detected_domain = detect_query_domain(query)
        }
        let search_query = clean_query_for_search(query)
        let topic_words = core_topic_words(query)

        let domain_results = self.domain_search(search_query, detected_domain, max_facts)
        let general_results = self.search(search_query, max_facts, "")
        let wolfram_results = self._wolfram_search(query, 2)

        let facts = []

        for wr in wolfram_results {
            if wr.snippet != "" and len(wr.snippet) > 10 {
                let conf = CONFIDENCE_BY_SOURCE.get(wr.source, 0.85)
                facts.append(new_retrieved_fact(
                    wr.snippet, wr.url, conf, "wolfram", wr.source
                ))
            }
        }

        for sr in domain_results {
            if sr.snippet != "" and len(sr.snippet) > 30 {
                if fact_is_metadata(sr.snippet) { continue }
                if not fact_relevant_to_topic(sr.snippet, topic_words) { continue }
                let conf = CONFIDENCE_BY_SOURCE.get(sr.source, 0.80)
                facts.append(new_retrieved_fact(
                    sr.snippet, sr.url, conf, detected_domain, sr.source
                ))
            }
        }

        for sr in general_results {
            if sr.snippet != "" and len(sr.snippet) > 30 {
                if fact_is_metadata(sr.snippet) { continue }
                if not fact_relevant_to_topic(sr.snippet, topic_words) { continue }
                let src_method = sr.source
                if src_method == "" { src_method = "search_snippet" }
                let conf = CONFIDENCE_BY_SOURCE.get(sr.source, 0.70)
                facts.append(new_retrieved_fact(
                    sr.snippet, sr.url, conf, "web", src_method
                ))
            }
        }

        let crawl_idx = 0
        for sr in general_results {
            if crawl_idx >= 2 { break }
            let crawled = self.crawl(sr.url)
            if crawled != None and len(crawled) > 100 {
                let paragraphs = []
                for p in crawled.split("\n") {
                    let stripped = p.strip()
                    if len(stripped) > 50 {
                        paragraphs.append(stripped)
                    }
                }
                let pi = 0
                for para in paragraphs {
                    if pi >= 3 { break }
                    let text = para[0:500]
                    if fact_is_metadata(text) {
                        pi += 1
                        continue
                    }
                    if not fact_relevant_to_topic(text, topic_words) {
                        pi += 1
                        continue
                    }
                    facts.append(new_retrieved_fact(
                        text, sr.url, 0.6, "web", "direct_crawl"
                    ))
                    pi += 1
                }
            }
            crawl_idx += 1
        }

        let seen_hashes = {}
        let deduped = []
        for fact in facts {
            if fact.content_hash not in seen_hashes {
                seen_hashes[fact.content_hash] = true
                deduped.append(fact)
            }
        }

        return deduped[0:max_facts]
    }

    /// ── Code Search ────────────────────────────────────────────────────

    fn search_code(self, query: string, language: string, max_results: int) -> List[any] {
        let code_results = []
        let code_query = query + " code example"
        if language != "" {
            code_query = language + " " + query + " example implementation"
        }

        let search_results = self.search(code_query, max_results, "")

        let all_wiki = true
        for sr in search_results {
            if sr.source != "wikipedia" {
                all_wiki = false
                break
            }
        }
        if len(search_results) == 0 or all_wiki {
            let alt_query = query + " " + language + " stackoverflow"
            let alt_results = self.search(alt_query, max_results, "")
            if len(alt_results) > 0 {
                search_results = alt_results
            }
        }

        for sr in search_results {
            let entry = {
                "title": sr.title,
                "url": sr.url,
                "snippet": sr.snippet,
                "source": sr.source,
                "type": "search_result",
                "code_blocks": [],
                "imports": [],
                "api_signatures": []
            }
            code_results.append(entry)
        }

        let crawl_domains = ["github.com", "docs.", "pkg.go.dev", "docs.rs",
                             "developer.mozilla", "cppreference", "pypi.org",
                             "stackoverflow.com"]
        let crawl_targets = []
        for sr in search_results {
            for d in crawl_domains {
                if d in sr.url {
                    crawl_targets.append(sr)
                    break
                }
            }
            if len(crawl_targets) >= 3 { break }
        }

        for sr in crawl_targets {
            let crawled = self.crawl(sr.url)
            if crawled == None { continue }

            let blocks = self._extract_code_blocks(crawled, language)
            let imports = self._extract_imports(crawled, language)
            let sigs = self._extract_api_signatures(crawled, language)

            for entry in code_results {
                if entry["url"] == sr.url {
                    entry["code_blocks"] = blocks[0:5]
                    entry["imports"] = imports[0:10]
                    entry["api_signatures"] = sigs[0:10]
                    entry["type"] = "crawled"
                    entry["full_text"] = crawled[0:3000]
                    break
                }
            }
        }

        return code_results
    }

    fn search_error_fix(self, error_message: string, language: string, code_context: string) -> List[any] {
        let lines = error_message.strip().split("\n")
        let clean_error = lines[len(lines) - 1][0:200]
        let query = language + " fix " + clean_error

        let results = self.search(query, 3, "")
        let fixes = []

        for sr in results {
            if sr.snippet != "" and len(sr.snippet) > 30 {
                fixes.append(sr.snippet)
            }
        }

        if len(fixes) < 2 {
            let ci = 0
            for sr in results {
                if ci >= 2 { break }
                let crawled = self.crawl(sr.url)
                if crawled != None {
                    let blocks = self._extract_code_blocks(crawled, language)
                    let bi = 0
                    for block in blocks {
                        if bi >= 2 { break }
                        fixes.append(block)
                        bi += 1
                    }
                }
                ci += 1
            }
        }

        return fixes[0:5]
    }

    fn lookup_package_api(self, package_name: string, language: string) -> Dict[string, any] {
        let api_urls = {
            "python": "https://pypi.org/project/" + package_name + "/",
            "javascript": "https://www.npmjs.com/package/" + package_name,
            "typescript": "https://www.npmjs.com/package/" + package_name,
            "go": "https://pkg.go.dev/" + package_name,
            "rust": "https://docs.rs/" + package_name + "/latest",
            "java": "https://mvnrepository.com/artifact/" + package_name
        }
        let install_commands = {
            "python": "pip install " + package_name,
            "javascript": "npm install " + package_name,
            "typescript": "npm install " + package_name,
            "go": "go get " + package_name,
            "rust": "cargo add " + package_name,
            "java": "<!-- Maven: " + package_name + " -->"
        }

        let info = {
            "package": package_name,
            "language": language,
            "description": "",
            "latest_version": "",
            "usage_examples": [],
            "api_functions": [],
            "install_command": install_commands.get(language, "")
        }

        let direct_url = api_urls.get(language, "")
        if direct_url != "" {
            let crawled = self.crawl(direct_url)
            if crawled != None {
                info["description"] = crawled[0:500]
                info["usage_examples"] = self._extract_code_blocks(crawled, language)[0:3]
                info["api_functions"] = self._extract_api_signatures(crawled, language)[0:10]
            }
        }

        let search_results = self.search(
            package_name + " " + language + " tutorial example usage", 3, "")
        for sr in search_results {
            let crawled = self.crawl(sr.url)
            if crawled != None {
                let examples = self._extract_code_blocks(crawled, language)
                let ei = 0
                for ex in examples {
                    if ei >= 2 { break }
                    info["usage_examples"].append(ex)
                    ei += 1
                }
            }
        }

        return info
    }

    fn _extract_code_blocks(self, text: string, language: string) -> List[any] {
        let blocks = []
        let lang_short = language[0:2]
        let pattern = "```(?:" + language + "|" + lang_short + ")?\\s*\\n(.*?)```"
        let matches = re.finditer(pattern, text, re.DOTALL)
        for match in matches {
            let block = match.group(1).strip()
            if len(block) > 20 {
                blocks.append(block)
            }
        }
        return blocks[0:10]
    }

    fn _extract_imports(self, text: string, language: string) -> List[any] {
        let import_patterns = {
            "python": "^(?:from\\s+\\S+\\s+import\\s+.+|import\\s+\\S+)",
            "javascript": "^(?:const\\s+\\{?\\s*\\w+.*\\}?\\s*=\\s*require\\(.+\\)|import\\s+.+\\s+from\\s+.+)",
            "typescript": "^(?:import\\s+.+\\s+from\\s+.+)",
            "go": "^(?:import\\s+(?:\"[^\"]+\"|[\\s\\S]*?\\)))",
            "rust": "^(?:use\\s+\\S+;|extern\\s+crate\\s+\\S+;)",
            "java": "^(?:import\\s+[\\w.]+\\*?;)"
        }
        let pattern = import_patterns.get(language, "")
        if pattern == "" {
            return []
        }
        let imports = {}
        let matches = re.finditer(pattern, text, re.MULTILINE)
        for match in matches {
            let imp = match.group(0).strip()
            if imp != "" {
                imports[imp] = true
            }
        }
        let sorted_imports = []
        for k in imports {
            sorted_imports.append(k)
        }
        sorted_imports.sort()
        return sorted_imports[0:20]
    }

    fn _extract_api_signatures(self, text: string, language: string) -> List[any] {
        let sig_patterns = {
            "python": "(?:def|class|async def)\\s+\\w+\\([^)]*\\)(?:\\s*->.*?)?:",
            "javascript": "(?:function|async function)\\s+\\w+\\([^)]*\\)",
            "typescript": "(?:function|async function|interface|type|class)\\s+\\w+[\\s\\S]*?[{;]",
            "go": "func\\s+(?:\\([^)]+\\)\\s+)?\\w+\\([^)]*\\)(?:\\s*(?:\\([^)]+\\)|\\w+))?",
            "rust": "(?:pub\\s+)?fn\\s+\\w+(?:<[^>]+>)?\\([^)]*\\)(?:\\s*->\\s*\\S+)?",
            "java": "(?:public|private|protected)\\s+(?:static\\s+)?\\w+\\s+\\w+\\([^)]*\\)"
        }
        let pattern = sig_patterns.get(language, "")
        if pattern == "" {
            return []
        }
        let sigs = {}
        let matches = re.finditer(pattern, text)
        for match in matches {
            let sig = match.group(0).strip()
            if len(sig) > 10 {
                sigs[sig] = true
            }
        }
        let sorted_sigs = []
        for k in sigs {
            sorted_sigs.append(k)
        }
        sorted_sigs.sort()
        return sorted_sigs[0:20]
    }

    /// ── Stats ──────────────────────────────────────────────────────────

    fn stats(self) -> Dict[string, int] {
        return {
            "searches": self._search_count,
            "crawls": self._crawl_count,
            "failures": self._failures
        }
    }
}

/// ── Exports ─────────────────────────────────────────────────────────────

export SearchResult, RetrievedFact
export new_search_result, new_retrieved_fact
export decode_ddg_url, strip_html_tags
export detect_query_domain, clean_query_for_search, core_topic_words
export fact_is_metadata, fact_relevant_to_topic
export WebRetrievalEngine
