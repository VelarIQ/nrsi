                let limit = count
                if limit > 10 { limit = 10 }
                let resp = c.get("https://api.congress.gov/v3/bill",
                    params: {"query": query, "limit": limit, "format": "json"})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let bills = resp.json().get("bills", [])
                let idx = 0
