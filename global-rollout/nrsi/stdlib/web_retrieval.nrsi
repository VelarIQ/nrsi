                    if idx >= count { break }
                    let title = bill.get("title", "")
                    let number = bill.get("number", "")
                    let congress = str(bill.get("congress", ""))
                    let btype = bill.get("type", "")
                    let action = bill.get("latestAction", {}).get("text", "")
                    let snippet = btype + number + " (" + congress + "th Congress): " + title + ". Latest: " + action
                    let url = bill.get("url", "")
                    if url == "" {
                        url = "https://congress.gov/bill/" + congress + "th-congress/" + btype.lower() + "/" + number
                    }
                    results.append(new_search_result(
                        btype + number + ": " + title[0:80],
                        url, snippet[0:500], "congress"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("Congress.gov search failed: " + str(e))
            return []
        }
    }

