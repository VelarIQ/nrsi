/// ── Query Cleaning ─────────────────────────────────────────────────────

let TEMPORAL_FILLER = ["tonight", "today", "tomorrow", "yesterday", "now",
    "right now", "currently", "lately", "recently",
    "this morning", "this evening", "this afternoon",
    "this week", "this month", "this year"]

let SEARCH_STOP = ["a", "an", "the", "i", "me", "my", "we", "our", "you", "your",
    "it", "its", "is", "am", "are", "was", "were", "be", "been",
    "have", "has", "had", "do", "does", "did", "will", "shall",
    "would", "could", "should", "can", "may", "might",
    "for", "to", "of", "in", "on", "at", "by", "with", "from",
    "and", "or", "but", "not", "so", "if", "then", "than",
    "just", "really", "very", "quite", "some", "any", "all",
    "about", "like", "also", "there", "here", "that", "this",
    "get", "got", "make", "made", "think", "know", "good"]

let QUESTION_PREFIXES = [
    "what should i ", "what should we ", "what is the best ",
    "what is ", "what are ", "what's ",
    "how does ", "how do ", "how to ", "how can i ", "how can we ",
    "how is ", "how are ",
    "why is ", "why do ", "why does ", "why are ",
    "tell me about ", "can you explain ", "explain ",
    "describe ", "define ", "what do you know about ",
    "is there ", "are there ", "does ", "do ",
    "can you ", "could you ", "would you ",
    "i want to know ", "i'd like to know "]

fn kw_in_text(kw: string, text: string, text_words: List[string]) -> bool {
    if " " in kw {
        return kw in text
    }
    for w in text_words {
        if w == kw {
            return true
        }
    }
    return false
}

fn detect_query_domain(query: string) -> string {
    let ql = query.lower()
    let ql_words = []
    for w in ql.split() {
        let bare = w.strip(".,;:!?\"'()-")
        ql_words.append(bare)
    }
    let scores = {}
    for domain in DOMAIN_SIGNALS {
        let keywords = DOMAIN_SIGNALS[domain]
        let c = 0
        for kw in keywords {
            if kw_in_text(kw, ql, ql_words) {
                c += 1
            }
        }
        if c > 0 {
            scores[domain] = c
        }
    }
    if len(scores) == 0 {
        return "general"
    }
    let best_domain = "general"
    let best_score = 0
    for d in scores {
        if scores[d] > best_score {
            best_score = scores[d]
            best_domain = d
        }
    }
    return best_domain
}

fn clean_query_for_search(query: string) -> string {
    let q = query.strip().rstrip("?!.")
    let tokens = q.split()
    let cleaned = []
    for tok in tokens {
        let bare = tok.strip(".,;:!?\"'()-").lower()
        let is_filler = false
        for filler in TEMPORAL_FILLER {
            if bare == filler {
                is_filler = true
                break
            }
        }
        if not is_filler {
            cleaned.append(tok)
        }
    }
    let result = " ".join(cleaned).strip()
    if len(result) >= 3 {
        return result
    }
    return query.strip()
}

fn core_topic_words(query: string) -> List[any] {
    let cleaned = clean_query_for_search(query)
    let words = []
    for w in cleaned.split() {
        if len(w) > 2 {
            let is_stop = false
            for sw in SEARCH_STOP {
                if w == sw {
                    is_stop = true
                    break
                }
            }
            if not is_stop {
                words.append(w)
            }
        }
    }
    return words
}

fn fact_is_metadata(text: string) -> bool {
    let low = text.lower().strip()
    if re.match("^[\\w\\s]{2,40}\\s*[-–—]\\s*wikipedia", low) {
        return true
    }
    if re.match("^\\d{4}-\\d{2}-\\d{2}", low) {
        return true
    }
    let meta_prefixes = ["search results", "results for", "related topics",
        "see also", "external links", "jump to", "from wikipedia",
        "category:", "template:", "portal:", "file:", "talk:"]
    for prefix in meta_prefixes {
        if low[0:len(prefix)] == prefix {
            return true
        }
    }
    if len(low) < 30 and " - " in low {
        return true
    }
    return false
}

fn fact_relevant_to_topic(fact_text: string, topic_words: List[string]) -> bool {
    if len(topic_words) == 0 {
        return true
    }
    let fl = fact_text.lower()
    let hits = 0
    for w in topic_words {
        if w in fl {
            hits += 1
        }
    }
    return hits >= 1
}

/// ── Confidence by Source ────────────────────────────────────────────────

let CONFIDENCE_BY_SOURCE = {
    "pubmed": 0.90, "clinicaltrials": 0.88, "openfda": 0.88,
    "arxiv": 0.85, "semantic_scholar": 0.85,
    "courtlistener": 0.88, "congress": 0.85,
    "fred": 0.90, "world_bank": 0.85, "sec_edgar": 0.85,
    "wolfram_short": 0.90, "wolfram_full": 0.88,
    "wikipedia": 0.75, "wikidata": 0.80,
    "geonames": 0.85, "oeis": 0.90,
    "stackexchange": 0.70, "newsapi": 0.70,
    "ddg_api_abstract": 0.72, "ddg_api_topic": 0.65
}

/// ── Web Retrieval Engine ───────────────────────────────────────────────

class WebRetrievalEngine {
    fn __init__(self, api_key: string = "", wolfram_id: string = "", http_client: Optional[any] = None) {
        let brave_key = os.environ.get("BRAVE_SEARCH_API_KEY", "")
        let wolf_key = os.environ.get("WOLFRAM_APP_ID", "")
        if api_key != "" {
            self._api_key = api_key
        } else {
            self._api_key = brave_key
        }
        if wolfram_id != "" {
            self._wolfram_id = wolfram_id
        } else {
            self._wolfram_id = wolf_key
        }
        self._client = http_client
        self._search_count = 0
        self._crawl_count = 0
        self._failures = 0
    }

    fn _get_client(self) -> any {
        if self._client == None {
            self._client = httpx.Client(
                timeout: CRAWL_TIMEOUT,
                headers: {"User-Agent": USER_AGENT},
                follow_redirects: true
            )
        }
        return self._client
    }

    fn _src_client(self) -> any {
        return httpx.Client(
            timeout: SEARCH_TIMEOUT,
            follow_redirects: true,
            headers: {"User-Agent": ACADEMIC_UA}
        )
    }

    /// ── Main Search Cascade ────────────────────────────────────────────

    fn search(self, query: string, count: int, locale: string) -> List[any] {
        self._search_count += 1

        if self._api_key != "" {
            let results = self._brave_search(query, count, locale)
            if len(results) > 0 {
                return results
            }
        }

        let results = self._ddg_api_search(query, count)
        if len(results) > 0 {
            return results
        }

        let results = self._fallback_search(query, count, locale)
        if len(results) > 0 {
            return results
        }

        return self._wikipedia_search(query, count)
    }

    /// ── Brave Search ───────────────────────────────────────────────────

    fn _brave_search(self, query: string, count: int, locale: string) -> List[any] {
        let client = self._get_client()
        try {
            let params = {"q": query, "count": count, "text_decorations": false}
            if locale != "" {
                let parts = locale.split("-")
                let lang = parts[0]
                params["search_lang"] = lang
                if len(parts) > 1 {
                    let country = parts[1].upper()
                    params["country"] = country
                }
            }
            let resp = client.get(
                BRAVE_SEARCH_URL,
                params: params,
                headers: {"X-Subscription-Token": self._api_key, "Accept": "application/json"},
                timeout: SEARCH_TIMEOUT
            )
            resp.raise_for_status()
            let data = resp.json()

            let results = []
            let web_results = data.get("web", {}).get("results", [])
            let idx = 0
            for item in web_results {
                if idx >= count {
                    break
                }
                results.append(new_search_result(
                    item.get("title", ""),
                    item.get("url", ""),
                    item.get("description", ""),
                    "brave_search"
                ))
                idx += 1
            }
            return results
        } catch(e) {
            logging.warning("Brave search failed: " + str(e) + ", falling back")
            self._failures += 1
            return []
        }
    }

    /// ── DDG API Search ─────────────────────────────────────────────────

    fn _ddg_api_search(self, query: string, count: int) -> List[any] {
        let client = self._get_client()
        try {
            let resp = client.get(DDG_API_URL, params: {
                "q": query, "format": "json", "no_html": "1",
                "skip_disambig": "1", "no_redirect": "1"
            }, timeout: SEARCH_TIMEOUT)
            if resp.status_code != 200 {
                return []
            }
            let data = resp.json()
            let results = []

            let abstract = data.get("Abstract", "")
            let abstract_url = data.get("AbstractURL", "")
            let abstract_source = data.get("AbstractSource", "")
            if abstract != "" and len(abstract) > 30 {
                let title = query
                if abstract_source != "" {
                    title = abstract_source + ": " + data.get("Heading", query)
                }
                let url = abstract_url
                if url == "" {
                    url = "https://duckduckgo.com/?q=" + query
                }
                results.append(new_search_result(
                    title, url, abstract[0:500], "ddg_api_abstract"
                ))
            }

            let answer = data.get("Answer", "")
            if answer != "" and len(answer) > 20 {
                results.append(new_search_result(
                    "DDG Answer: " + query,
                    "https://duckduckgo.com/?q=" + query,
                    answer[0:500],
                    "ddg_api_answer"
                ))
            }

            let topics = data.get("RelatedTopics", [])
            let tidx = 0
            for topic in topics {
                if tidx >= count {
                    break
                }
                if typeof(topic) == "dict" {
                    let text = topic.get("Text", "")
                    let url = topic.get("FirstURL", "")
                    if text != "" and len(text) > 30 and url != "" {
                        let title = text[0:80]
                        if " - " in text {
                            title = text.split(" - ")[0][0:80]
                        }
                        results.append(new_search_result(
                            title, url, text[0:500], "ddg_api_topic"
                        ))
                    }
                    let subtopics = topic.get("Topics", [])
                    for sub in subtopics {
                        if typeof(sub) == "dict" and sub.get("Text") != "" {
                            results.append(new_search_result(
                                sub.get("Text", "")[0:80],
                                sub.get("FirstURL", ""),
                                sub.get("Text", "")[0:500],
                                "ddg_api_subtopic"
                            ))
                        }
                    }
                }
                tidx += 1
            }

            return results[0:count]
        } catch(e) {
            logging.debug("DDG API search failed: " + str(e))
            return []
        }
    }

    /// ── Wolfram Alpha ──────────────────────────────────────────────────

    fn _wolfram_search(self, query: string, count: int) -> List[any] {
        if self._wolfram_id == "" {
            return []
        }
        try {
            let wa_client = httpx.Client(timeout: SEARCH_TIMEOUT, follow_redirects: true)
            try {
                let short_resp = wa_client.get(
                    "https://api.wolframalpha.com/v1/result",
                    params: {"appid": self._wolfram_id, "i": query}
                )
                let short_answer = ""
                if short_resp.status_code == 200 {
                    short_answer = short_resp.text.strip()
                }

                let full_resp = wa_client.get(
                    "https://api.wolframalpha.com/v2/query",
                    params: {
                        "appid": self._wolfram_id, "input": query,
                        "format": "plaintext", "output": "json"
                    }
                )
                let results = []

                if short_answer != "" and len(short_answer) > 5 {
                    results.append(new_search_result(
                        "Wolfram|Alpha: " + query[0:60],
                        "https://www.wolframalpha.com/input?i=" + query,
                        short_answer[0:500],
                        "wolfram_short"
                    ))
                }

                if full_resp.status_code == 200 {
                    let data = full_resp.json()
                    let pods = data.get("queryresult", {}).get("pods", [])
                    for pod in pods {
                        let pod_title = pod.get("title", "")
                        if pod_title.lower() == "input" or pod_title.lower() == "input interpretation" {
                            continue
                        }
                        let subpods = pod.get("subpods", [])
                        for subpod in subpods {
                            let plaintext = subpod.get("plaintext", "")
                            if plaintext != "" and len(plaintext) > 10 {
                                results.append(new_search_result(
                                    "Wolfram|Alpha (" + pod_title + ")",
                                    "https://www.wolframalpha.com/input?i=" + query,
                                    plaintext[0:500],
                                    "wolfram_full"
                                ))
                                if len(results) >= count {
                                    break
                                }
                            }
                        }
                        if len(results) >= count {
                            break
                        }
                    }
                }

                return results[0:count]
            } catch(inner_err) {
                wa_client.close()
                raise inner_err
            }
        } catch(e) {
            logging.debug("Wolfram search failed: " + str(e))
            return []
        }
    }

    /// ── DDG HTML Fallback ──────────────────────────────────────────────

    fn _fallback_search(self, query: string, count: int, locale: string) -> List[any] {
        let client = self._get_client()
        let params = {"q": query}
        if locale != "" {
            params["kl"] = locale.replace("-", "_")
        }

        let attempt = 0
        while attempt < 3 {
            try {
                let resp = client.get(
                    "https://html.duckduckgo.com/html/",
                    params: params,
                    headers: {"User-Agent": USER_AGENT},
                    timeout: SEARCH_TIMEOUT
                )
                if resp.status_code == 202 {
                    time.sleep(1.5 * (attempt + 1))
                    attempt += 1
                    continue
                }
                resp.raise_for_status()
                let html = resp.text

                let results = []
                let matches = re.finditer(
                    "<a rel=\"nofollow\" class=\"result__a\" href=\"([^\"]+)\"[^>]*>(.*?)</a>.*?" +
                    "<a class=\"result__snippet\"[^>]*>(.*?)</a>",
                    html, re.DOTALL
                )
                for match in matches {
                    if len(results) >= count {
                        break
                    }
                    let raw_url = match.group(1)
                    let url = decode_ddg_url(raw_url)
                    let title = strip_html_tags(match.group(2)).strip()
                    let snippet = strip_html_tags(match.group(3)).strip()
                    if url != "" and title != "" {
                        results.append(new_search_result(
                            title, url, snippet, "duckduckgo_html"
                        ))
                    }
                }
                if len(results) > 0 {
                    return results
                }
                time.sleep(0.5 * (attempt + 1))
            } catch(e) {
                if attempt >= 2 {
                    logging.warning("Fallback search failed after 3 attempts: " + str(e))
                    self._failures += 1
                    return []
                }
                time.sleep(0.5)
            }
            attempt += 1
        }
        return []
    }

    /// ── Wikipedia Search ───────────────────────────────────────────────

    fn _wikipedia_search(self, query: string, count: int) -> List[any] {
        try {
            let wiki_ua = "PRISM-NRS/2.0 (https://velariq.ai; team@velariq.ai)"
            let wc = httpx.Client(timeout: SEARCH_TIMEOUT, headers: {"User-Agent": wiki_ua})
            try {
                let resp = wc.get("https://en.wikipedia.org/w/api.php", params: {
                    "action": "query", "list": "search", "srsearch": query,
                    "format": "json", "srlimit": count, "utf8": "1"
                })
                if resp.status_code != 200 {
                    wc.close()
                    return []
                }
                let data = resp.json()
                let items = data.get("query", {}).get("search", [])
                let results = []
                let idx = 0
                for item in items {
                    if idx >= count {
                        break
                    }
                    let title = item.get("title", "")
                    let snippet = strip_html_tags(item.get("snippet", "")).strip()
                    let url = "https://en.wikipedia.org/wiki/" + title.replace(" ", "_")
                    if title != "" and snippet != "" {
                        results.append(new_search_result(title, url, snippet, "wikipedia"))
                    }
                    idx += 1
                }

                let enrich_idx = 0
                for sr in results {
                    if enrich_idx >= 2 {
                        break
                    }
                    try {
                        let summary = wc.get(
                            "https://en.wikipedia.org/api/rest_v1/page/summary/" + sr.title.replace(" ", "_")
                        )
                        if summary.status_code == 200 {
                            let extract = summary.json().get("extract", "")
                            if extract != "" and len(extract) > len(sr.snippet) {
                                sr.snippet = extract[0:500]
                            }
                        }
                    } catch(inner_err) {
                        pass
                    }
                    enrich_idx += 1
                }

                wc.close()
                return results
            } catch(inner_err) {
                wc.close()
                return []
            }
        } catch(e) {
            logging.warning("Wikipedia search failed: " + str(e))
            return []
        }
    }

    /// ── Domain-Specific Sources ────────────────────────────────────────

    fn _pubmed_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let sr = c.get("https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi",
                    params: {"db": "pubmed", "term": query, "retmax": count,
                             "retmode": "json", "sort": "relevance"})
                if sr.status_code != 200 {
                    c.close()
                    return []
                }
                let ids = sr.json().get("esearchresult", {}).get("idlist", [])
                if len(ids) == 0 {
                    c.close()
                    return []
                }
                let detail = c.get("https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi",
                    params: {"db": "pubmed", "id": ",".join(ids), "retmode": "json"})
                if detail.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let idx = 0
                for uid in ids {
                    if idx >= count {
                        break
                    }
                    let doc = detail.json().get("result", {}).get(uid, {})
                    let title = doc.get("title", "")
                    let snippet = title + ". " + doc.get("source", "") + " (" + doc.get("pubdate", "") + ")."
                    let authors_list = doc.get("authors", [])
                    if len(authors_list) > 0 {
                        let author_names = []
                        let ai = 0
                        for a in authors_list {
                            if ai >= 3 { break }
                            author_names.append(a.get("name", ""))
                            ai += 1
                        }
                        snippet = snippet + " Authors: " + ", ".join(author_names) + "."
                    }
                    results.append(new_search_result(
                        title, "https://pubmed.ncbi.nlm.nih.gov/" + uid + "/",
                        snippet[0:500], "pubmed"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("PubMed search failed: " + str(e))
            return []
        }
    }

    fn _openfda_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let limit = count
                if limit > 5 { limit = 5 }
                let resp = c.get("https://api.fda.gov/drug/label.json",
                    params: {"search": query, "limit": limit})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let items = resp.json().get("results", [])
                let idx = 0
                for item in items {
                    if idx >= count { break }
                    let brand = item.get("openfda", {}).get("brand_name", [""])
                    let generic = item.get("openfda", {}).get("generic_name", [""])
                    let name = ""
                    if len(brand) > 0 and brand[0] != "" {
                        name = brand[0]
                    } else if len(generic) > 0 {
                        name = generic[0]
                    }
                    let purpose = " ".join(item.get("purpose", []))[0:200]
                    let warnings = " ".join(item.get("warnings", []))[0:200]
                    let snippet = (name + ": " + purpose + " " + warnings).strip()
                    results.append(new_search_result(
                        "FDA: " + name, "https://open.fda.gov/",
                        snippet[0:500], "openfda"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("OpenFDA search failed: " + str(e))
            return []
        }
    }

    fn _clinicaltrials_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let page_size = count
                if page_size > 10 { page_size = 10 }
                let resp = c.get("https://clinicaltrials.gov/api/v2/studies",
                    params: {"query.term": query, "pageSize": page_size, "format": "json"})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let studies = resp.json().get("studies", [])
                let idx = 0
                for study in studies {
                    if idx >= count { break }
                    let proto = study.get("protocolSection", {})
                    let ident = proto.get("identificationModule", {})
                    let title = ident.get("briefTitle", "")
                    if title == "" {
                        title = ident.get("officialTitle", "")
                    }
                    let nct = ident.get("nctId", "")
                    let status = proto.get("statusModule", {}).get("overallStatus", "")
                    let desc = proto.get("descriptionModule", {}).get("briefSummary", "")[0:300]
                    let snippet = title + ". Status: " + status + ". " + desc
                    results.append(new_search_result(
                        "Trial " + nct + ": " + title[0:80],
                        "https://clinicaltrials.gov/study/" + nct,
                        snippet[0:500], "clinicaltrials"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("ClinicalTrials search failed: " + str(e))
            return []
        }
    }

    fn _arxiv_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let resp = c.get("http://export.arxiv.org/api/query",
                    params: {"search_query": "all:" + query, "max_results": count, "sortBy": "relevance"})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let entries = re.finditer("<entry>(.*?)</entry>", resp.text, re.DOTALL)
                for entry in entries {
                    let block = entry.group(1)
                    let title_match = re.search("<title>(.*?)</title>", block, re.DOTALL)
                    let summary_match = re.search("<summary>(.*?)</summary>", block, re.DOTALL)
                    let link_match = re.search("<id>(.*?)</id>", block)
                    if title_match != None and summary_match != None {
                        let t = re.sub("\\s+", " ", title_match.group(1)).strip()
                        let s = re.sub("\\s+", " ", summary_match.group(1)).strip()[0:400]
                        let url = ""
                        if link_match != None {
                            url = link_match.group(1).strip()
                        }
                        results.append(new_search_result(t, url, s, "arxiv"))
                    }
                }
                c.close()
                return results[0:count]
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("arXiv search failed: " + str(e))
            return []
        }
    }

    fn _semantic_scholar_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let limit = count
                if limit > 10 { limit = 10 }
                let resp = c.get("https://api.semanticscholar.org/graph/v1/paper/search",
                    params: {"query": query, "limit": limit,
                             "fields": "title,abstract,year,citationCount,url"})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let papers = resp.json().get("data", [])
                let idx = 0
                for paper in papers {
                    if idx >= count { break }
                    let title = paper.get("title", "")
                    let abstract = paper.get("abstract", "")
                    if abstract == None { abstract = "" }
                    abstract = abstract[0:400]
                    let year = str(paper.get("year", ""))
                    let cites = str(paper.get("citationCount", 0))
                    let snippet = title + " (" + year + ", " + cites + " citations). " + abstract
                    results.append(new_search_result(
                        title, paper.get("url", ""),
                        snippet[0:500], "semantic_scholar"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("Semantic Scholar search failed: " + str(e))
            return []
        }
    }

    fn _oeis_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let resp = c.get("https://oeis.org/search", params: {"q": query, "fmt": "json"})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let results = []
                let seqs = resp.json().get("results", [])
                let idx = 0
                for seq in seqs {
                    if idx >= count { break }
                    let name = seq.get("name", "")
                    let number = seq.get("number", 0)
                    let data_vals = seq.get("data", [])
                    let data_strs = []
                    let di = 0
                    for x in data_vals {
                        if di >= 15 { break }
                        data_strs.append(str(x))
                        di += 1
                    }
                    let data = ",".join(data_strs)
                    let num_str = str(number)
                    while len(num_str) < 6 { num_str = "0" + num_str }
                    let snippet = "A" + num_str + ": " + name + ". Sequence: " + data
                    results.append(new_search_result(
                        "OEIS A" + num_str + ": " + name[0:60],
                        "https://oeis.org/A" + num_str,
                        snippet[0:500], "oeis"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("OEIS search failed: " + str(e))
            return []
        }
    }

