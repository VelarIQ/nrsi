    fn _world_bank_search(self, query: string, count: int) -> List[any] {
        try {
            let c = self._src_client()
            try {
                let limit = count
                if limit > 10 { limit = 10 }
                let resp = c.get("https://api.worldbank.org/v2/indicator",
                    params: {"format": "json", "per_page": limit, "source": "2"})
                if resp.status_code != 200 {
                    c.close()
                    return []
                }
                let data = resp.json()
                let indicators = []
                if typeof(data) == "list" and len(data) > 1 {
                    indicators = data[1]
                }
                let q_lower = query.lower()
                let q_words = []
                for w in q_lower.split() {
                    if len(w) > 3 {
                        q_words.append(w)
                    }
                }
                let matched = []
                for ind in indicators {
                    let combined = (ind.get("name", "") + ind.get("sourceNote", "")).lower()
                    for w in q_words {
                        if w in combined {
                            matched.append(ind)
                            break
                        }
                    }
                }
                let results = []
                let idx = 0
                for ind in matched {
                    if idx >= count { break }
                    let name = ind.get("name", "")
                    let note = ind.get("sourceNote", "")
                    if note == None { note = "" }
                    note = note[0:300]
                    let iid = ind.get("id", "")
                    let snippet = name + ". " + note
                    results.append(new_search_result(
                        "World Bank: " + name[0:80],
                        "https://data.worldbank.org/indicator/" + iid,
                        snippet[0:500], "world_bank"
                    ))
                    idx += 1
                }
                c.close()
                return results
            } catch(inner_err) {
                c.close()
                return []
            }
        } catch(e) {
            logging.debug("World Bank search failed: " + str(e))
            return []
        }
    }

