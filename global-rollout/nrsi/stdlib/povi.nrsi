/// Proof of Validated Inference (PoVI) — Determinism-Based Consensus.
///
/// NRS determinism means: same input -> same output. Always.
/// PoVI exploits this: submit a query to >=3 independent validators.
/// If all agree, the answer is mathematically confirmed.
/// Any disagreement indicates compromise.
///
/// Mechanism:
///   1. A transaction/query is submitted to >= 3 independent NRS validator instances.
///   2. Each validator processes through its full T0-T4 pipeline.
///   3. Each returns: validation_result, h_score, activation_hash.
///   4. Because NRS is deterministic, all honest validators MUST produce identical results.
///   5. Any disagreement flags the disagreeing validator for attestation review.
///
/// Consensus rules:
///   - Unanimous agreement = CONFIRMED (millisecond confirmation)
///   - Supermajority (>= 2/3) = ACCEPTED with minority flagged
///   - No majority = REJECTED, all validators re-attested
///
/// Performance:
///   ~50 ms confirmation (vs Bitcoin ~10 min, Ethereum ~12 s, Solana ~400 ms)
///
/// Security:
///   Forgery probability < 2^(-N) where N = total neuron count: attacker must
///   compromise all n validators simultaneously, each with unique activation
///   fingerprints. Validators are selected from independent providers.
///   At production scale (111M neurons), P_forgery < 2^(-100M).
///
/// Applications:
///   1. Cross-chain oracle — deterministic verification replaces economic incentives
///   2. Micropayments — per-query payment channels with instant PoVI settlement
///   3. AI service marketplace — per-query compensation with cryptographic proof
///   4. L4 immutable facts — unanimous cross-region validation before archival
///
/// Patent-covered: PoVI consensus, determinism-based validation, cross-region consensus.

module povi


import time from "std/time"
import hashlib from "std/hashlib"

// ─── Verdict Enum ───────────────────────────────────────────────────

enum PoVIVerdict {
    CONFIRMED,
    ACCEPTED,
    REJECTED,
    PENDING,
    TIMEOUT
}

// ─── ValidatorResult ────────────────────────────────────────────────

type ValidatorResult {
    validator_id: string,
    provider: string,
    region: string,
    activation_hash: string,
    h_score: float,
    validation_result: string,
    processing_mode: string,
    tier: string,
    processing_time_ms: float,
    timestamp_ms: int
}

/// Factory: build a ValidatorResult with automatic timestamp.
fn make_validator_result(
    validator_id: string,
    provider: string,
    region: string,
    activation_hash: string,
    h_score: float,
    validation_result: string,
    processing_mode: string,
    tier: string,
    processing_time_ms: float
) -> ValidatorResult {
    return ValidatorResult {
        validator_id: validator_id,
        provider: provider,
        region: region,
        activation_hash: activation_hash,
        h_score: h_score,
        validation_result: validation_result,
        processing_mode: processing_mode,
        tier: tier,
        processing_time_ms: processing_time_ms,
        timestamp_ms: int(time.time() * 1000)
    }
}

/// Deterministic hash of the validation outcome — honest validators with
/// identical inputs MUST produce the same hash.
fn validator_result_hash(r: ValidatorResult) -> string {
    let payload = r.activation_hash + ":" + format(r.h_score, ".6f") + ":" + r.validation_result + ":" + r.processing_mode + ":" + r.tier
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()
}

// ─── PoVIConsensusResult ────────────────────────────────────────────

type PoVIConsensusResult {
    query_hash: string,
    verdict: PoVIVerdict,
    validators_count: int,
    agreeing_count: int,
    disagreeing_validators: List[string],
    consensus_hash: string,
    h_score: float,
    validation_result: string,
    processing_time_ms: float,
    timestamp_ms: int,
    round_id: string,
    proof: Dict[string, Any]
}

// ─── PoVIProof ──────────────────────────────────────────────────────

type PoVIProof {
    round_id: string,
    query_hash: string,
    consensus_hash: string,
    verdict: string,
    validators: List[string],
    regions: List[string],
    providers: List[string],
    h_score: float,
    timestamp_ms: int
}

/// Cryptographic proof hash of the PoVI receipt.
fn proof_hash(p: PoVIProof) -> string {
    let sorted_vals = sorted(p.validators)
    let joined_vals = ",".join(sorted_vals)
    let payload = p.round_id + ":" + p.query_hash + ":" + p.consensus_hash + ":" + p.verdict + ":" + joined_vals + ":" + str(p.timestamp_ms)
    return hashlib.sha256(payload.encode("utf-8")).hexdigest()
}

/// Serialize a PoVIProof to a dictionary representation.
fn proof_to_dict(p: PoVIProof) -> Dict[string, Any] {
    return {
        "round_id": p.round_id,
        "query_hash": p.query_hash,
        "consensus_hash": p.consensus_hash,
        "verdict": p.verdict,
        "validators": p.validators,
        "regions": p.regions,
        "providers": p.providers,
        "h_score": p.h_score,
        "proof_hash": proof_hash(p),
        "timestamp_ms": p.timestamp_ms
    }
}

// ─── Sort helper (converted from lambda) ────────────────────────────

fn _trust_score_key(v: Dict[string, Any]) -> float {
    return float(v["trust_score"])
}

// ─── Validator Selection ────────────────────────────────────────────
///
/// Requirements:
///   - Minimum 3 validators
///   - From different providers when possible
///   - From different regions when possible (cross-region consensus)
///   - Only ATTESTED trust-level entities eligible

class ValidatorSelector {
    fn init(self, min_validators: int = 3, prefer_cross_region: bool = true) {
        self.min_validators = max(3, min_validators)
        self.prefer_cross_region = prefer_cross_region
        self._registry = []
    }

    fn register_validator(self, validator_id: string, provider: string,
                          region: string, trust_score: float) {
        self._registry.append({
            "validator_id": validator_id,
            "provider": provider,
            "region": region,
            "trust_score": trust_score
        })
    }

    /// Select validators, preferring cross-provider and cross-region diversity.
    fn select(self, count: Optional[int]) -> List[any] {
        let n = count
        if n == None {
            n = self.min_validators
        }
        if len(self._registry) < n {
            raise ValueError("Need " + str(n) + " validators but only " + str(len(self._registry)) + " registered")
        }

        let sorted_by_trust = sorted(self._registry, key=_trust_score_key, reverse=true)

        if not self.prefer_cross_region {
            return sorted_by_trust[:n]
        }

        let selected = []
        let used_providers = Set()
        let used_regions = Set()

        for v in sorted_by_trust {
            if len(selected) >= n {
                break
            }
            if v["provider"] not in used_providers or v["region"] not in used_regions {
                selected.append(v)
                used_providers.add(v["provider"])
                used_regions.add(v["region"])
            }
        }

        for v in sorted_by_trust {
            if len(selected) >= n {
                break
            }
            if v not in selected {
                selected.append(v)
            }
        }

        return selected[:n]
    }
}

// ─── Consensus Engine ───────────────────────────────────────────────
///
/// Flow:
///   1. Receive query hash + validator results
///   2. Group results by result_hash (deterministic: honest validators match)
///   3. Determine verdict: CONFIRMED, ACCEPTED, or REJECTED
///   4. Generate proof

class PoVIConsensusEngine {
    fn init(self, require_unanimous: bool = false) {
        self.require_unanimous = require_unanimous
        self.SUPERMAJORITY_THRESHOLD = 2.0 / 3.0
        self._rounds = {}
    }

    fn _generate_round_id(self, query_hash: string) -> string {
        let payload = "povi:" + query_hash + ":" + str(time.time())
        return hashlib.sha256(payload.encode("utf-8")).hexdigest()[:16]
    }

    /// Run a PoVI consensus round on collected validator results.
    fn execute_round(self, query_hash: string,
                     results: List[ValidatorResult]) -> PoVIConsensusResult {
        let start_ms = time.monotonic() * 1000
        let round_id = self._generate_round_id(query_hash)

        if len(results) < 3 {
            let reject_ids = []
            for r in results {
                reject_ids.append(r.validator_id)
            }
            return PoVIConsensusResult {
                query_hash: query_hash,
                verdict: PoVIVerdict.REJECTED,
                validators_count: len(results),
                agreeing_count: 0,
                disagreeing_validators: reject_ids,
                consensus_hash: "",
                h_score: 0.0,
                validation_result: "",
                processing_time_ms: 0.0,
                timestamp_ms: int(time.time() * 1000),
                round_id: round_id,
                proof: {"reason": "insufficient validators: " + str(len(results)) + " < 3"}
            }
        }

        let groups = {}
        for r in results {
            let rh = validator_result_hash(r)
            if rh not in groups {
                groups[rh] = []
            }
            groups[rh].append(r)
        }

        let majority_hash = ""
        let majority_count = 0
        for k in groups {
            if len(groups[k]) > majority_count {
                majority_count = len(groups[k])
                majority_hash = k
            }
        }
        let majority_group = groups[majority_hash]

        let minority_validators = []
        for rh in groups {
            if rh != majority_hash {
                for r in groups[rh] {
                    minority_validators.append(r.validator_id)
                }
            }
        }

        let verdict = PoVIVerdict.REJECTED
        if majority_count == len(results) {
            verdict = PoVIVerdict.CONFIRMED
        } else if majority_count / len(results) >= self.SUPERMAJORITY_THRESHOLD {
            if self.require_unanimous {
                verdict = PoVIVerdict.REJECTED
            } else {
                verdict = PoVIVerdict.ACCEPTED
            }
        }

        let agreed_result = majority_group[0]
        let elapsed_ms = time.monotonic() * 1000 - start_ms

        let group_sizes = {}
        for k in groups {
            group_sizes[k] = len(groups[k])
        }

        let consensus = PoVIConsensusResult {
            query_hash: query_hash,
            verdict: verdict,
            validators_count: len(results),
            agreeing_count: majority_count,
            disagreeing_validators: minority_validators,
            consensus_hash: majority_hash,
            h_score: agreed_result.h_score,
            validation_result: agreed_result.validation_result,
            processing_time_ms: round(elapsed_ms, 2),
            timestamp_ms: int(time.time() * 1000),
            round_id: round_id,
            proof: {
                "majority_hash": majority_hash,
                "majority_count": majority_count,
                "total_validators": len(results),
                "groups": group_sizes
            }
        }

        self._rounds[round_id] = consensus
        return consensus
    }

    /// Generate a PoVI proof receipt from a consensus result.
    fn generate_proof(self, consensus: PoVIConsensusResult,
                      results: List[ValidatorResult]) -> PoVIProof {
        let validator_ids = []
        let region_set = Set()
        let provider_set = Set()
        for r in results {
            validator_ids.append(r.validator_id)
            region_set.add(r.region)
            provider_set.add(r.provider)
        }
        return PoVIProof {
            round_id: consensus.round_id,
            query_hash: consensus.query_hash,
            consensus_hash: consensus.consensus_hash,
            verdict: consensus.verdict.value,
            validators: validator_ids,
            regions: list(region_set),
            providers: list(provider_set),
            h_score: consensus.h_score,
            timestamp_ms: consensus.timestamp_ms
        }
    }

    fn get_round(self, round_id: string) -> Optional[PoVIConsensusResult] {
        return self._rounds.get(round_id)
    }
}

// ─── L4 Immutable Fact Consensus ────────────────────────────────────
///
/// L4 facts require UNANIMOUS cross-region validation from >= 3 regions.
/// Once archived, facts are append-only and cannot be modified.

class L4FactConsensus {
    fn init(self) {
        self._engine = PoVIConsensusEngine(true)
        self._archived = {}
    }

    /// Validate a fact for L4 archival. Requires unanimous cross-region agreement.
    fn validate_for_archive(self, fact_hash: string,
                            results: List[ValidatorResult]) -> Tuple[bool, PoVIConsensusResult] {
        let regions = Set()
        for r in results {
            regions.add(r.region)
        }

        if len(regions) < 3 {
            let consensus = PoVIConsensusResult {
                query_hash: fact_hash,
                verdict: PoVIVerdict.REJECTED,
                validators_count: len(results),
                agreeing_count: 0,
                disagreeing_validators: [],
                consensus_hash: "",
                h_score: 0.0,
                validation_result: "",
                processing_time_ms: 0.0,
                timestamp_ms: int(time.time() * 1000),
                round_id: "",
                proof: {"reason": "cross-region requirement not met: " + str(len(regions)) + " < 3 regions"}
            }
            return (false, consensus)
        }

        let consensus = self._engine.execute_round(fact_hash, results)
        if consensus.verdict == PoVIVerdict.CONFIRMED {
            self._archived[fact_hash] = {
                "consensus_hash": consensus.consensus_hash,
                "regions": list(regions),
                "validators": consensus.validators_count,
                "timestamp_ms": consensus.timestamp_ms,
                "round_id": consensus.round_id
            }
            return (true, consensus)
        }

        return (false, consensus)
    }

    fn is_archived(self, fact_hash: string) -> bool {
        return fact_hash in self._archived
    }

    fn get_archive_proof(self, fact_hash: string) -> Optional[Dict[string, Any]] {
        return self._archived.get(fact_hash)
    }
}

// ─── PoVI Consensus Gate ────────────────────────────────────────────

gate povi_consensus(data: raw[ValidatorResult]) -> validated[ValidatorResult] {
    require len(data.validators) >= 3
    validate multi_source_agreement
    validate cross_region_diversity
}

// ─── Exports ────────────────────────────────────────────────────────

export PoVIVerdict
export ValidatorResult, PoVIConsensusResult, PoVIProof
export make_validator_result, validator_result_hash
export proof_hash, proof_to_dict
export ValidatorSelector, PoVIConsensusEngine, L4FactConsensus
export povi_consensus
