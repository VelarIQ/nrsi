/// ── Porter Stemmer ─────────────────────────────────────────────────────

let STEP2_PAIRS: List[List[string]] = [
    ["ational", "ate"], ["tional", "tion"], ["enci", "ence"],
    ["anci", "ance"], ["izer", "ize"], ["abli", "able"],
    ["alli", "al"], ["entli", "ent"], ["eli", "e"],
    ["ousli", "ous"], ["ization", "ize"], ["ation", "ate"],
    ["ator", "ate"], ["alism", "al"], ["iveness", "ive"],
    ["fulness", "ful"], ["ousness", "ous"], ["aliti", "al"],
    ["iviti", "ive"], ["biliti", "ble"], ["logi", "log"]
]

let STEP3_PAIRS: List[List[string]] = [
    ["icate", "ic"], ["ative", ""], ["alize", "al"],
    ["iciti", "ic"], ["ical", "ic"], ["ful", ""], ["ness", ""]
]

let STEP4_SUFFIXES: List[string] = [
    "al", "ance", "ence", "er", "ic", "able", "ible", "ant",
    "ement", "ment", "ent", "ou", "ism", "ate", "iti", "ous",
    "ive", "ize"
]

class PorterStemmer {
    fn new() -> PorterStemmer {
        return PorterStemmer {}
    }

    fn _is_consonant(self, word: string, i: int) -> bool {
        let ch = word[i]
        if ch in "aeiou" {
            return false
        }
        if ch == "y" {
            return i == 0 || !self._is_consonant(word, i - 1)
        }
        return true
    }

    fn _measure(self, stem: string) -> int {
        if stem == "" { return 0 }
        let cv: List[string] = []
        let i = 0
        while i < stem.len() {
            let tag = "V"
            if self._is_consonant(stem, i) { tag = "C" }
            if cv.len() == 0 || cv[cv.len() - 1] != tag {
                cv.append(tag)
            }
            i += 1
        }
        let cv_str = cv.join("")
        let count = 0
        let j = 0
        while j < cv_str.len() - 1 {
            if cv_str[j] == "V" && cv_str[j + 1] == "C" {
                count += 1
            }
            j += 1
        }
        return count
    }

    fn _has_vowel(self, stem: string) -> bool {
        let i = 0
        while i < stem.len() {
            if !self._is_consonant(stem, i) {
                return true
            }
            i += 1
        }
        return false
    }

    fn _ends_double_consonant(self, word: string) -> bool {
        return word.len() >= 2 && word[-1] == word[-2] && self._is_consonant(word, word.len() - 1)
    }

    fn _ends_cvc(self, word: string) -> bool {
        if word.len() < 3 { return false }
        return self._is_consonant(word, word.len() - 1) &&
               !self._is_consonant(word, word.len() - 2) &&
               self._is_consonant(word, word.len() - 3) &&
               word[-1] not in "wxy"
    }

    fn _step1a(self, w: string) -> string {
        if w.endswith("sses") { return w[0:-2] }
        if w.endswith("ies") { return w[0:-2] }
        if w.endswith("ss") { return w }
        if w.endswith("s") { return w[0:-1] }
        return w
    }

    fn _step1b(self, w: string) -> string {
        if w.endswith("eed") {
            let stem = w[0:-3]
            if self._measure(stem) > 0 { return stem + "ee" }
            return w
        }

        let removed = false
        if w.endswith("ed") {
            let stem = w[0:-2]
            if self._has_vowel(stem) {
                w = stem
                removed = true
            }
        } else if w.endswith("ing") {
            let stem = w[0:-3]
            if self._has_vowel(stem) {
                w = stem
                removed = true
            }
        }

        if removed {
            if w.endswith("at") || w.endswith("bl") || w.endswith("iz") {
                return w + "e"
            }
            if self._ends_double_consonant(w) && w[-1] not in "lsz" {
                return w[0:-1]
            }
            if self._measure(w) == 1 && self._ends_cvc(w) {
                return w + "e"
            }
        }
        return w
    }

    fn _step1c(self, w: string) -> string {
        if w.endswith("y") && self._has_vowel(w[0:-1]) {
            return w[0:-1] + "i"
        }
        return w
    }

    fn _step2(self, w: string) -> string {
        for pair in STEP2_PAIRS {
            let suffix = pair[0]
            let repl = pair[1]
            if w.endswith(suffix) {
                let stem = w[0:-suffix.len()]
                if self._measure(stem) > 0 { return stem + repl }
                return w
            }
        }
        return w
    }

    fn _step3(self, w: string) -> string {
        for pair in STEP3_PAIRS {
            let suffix = pair[0]
            let repl = pair[1]
            if w.endswith(suffix) {
                let stem = w[0:-suffix.len()]
                if self._measure(stem) > 0 { return stem + repl }
                return w
            }
        }
        return w
    }

    fn _step4(self, w: string) -> string {
        for suffix in STEP4_SUFFIXES {
            if w.endswith(suffix) {
                let stem = w[0:-suffix.len()]
                if self._measure(stem) > 1 { return stem }
                return w
            }
        }
        if w.endswith("ion") {
            let stem = w[0:-3]
            if stem != "" && stem[-1] in "st" && self._measure(stem) > 1 {
                return stem
            }
        }
        return w
    }

    fn _step5a(self, w: string) -> string {
        if w.endswith("e") {
            let stem = w[0:-1]
            let m = self._measure(stem)
            if m > 1 { return stem }
            if m == 1 && !self._ends_cvc(stem) { return stem }
        }
        return w
    }

    fn _step5b(self, w: string) -> string {
        if self._measure(w) > 1 && self._ends_double_consonant(w) && w[-1] == "l" {
            return w[0:-1]
        }
        return w
    }

    fn stem(self, word: string) -> string {
        let w = word.lower()
        if w.len() <= 2 { return w }
        w = self._step1a(w)
        w = self._step1b(w)
        w = self._step1c(w)
        w = self._step2(w)
        w = self._step3(w)
        w = self._step4(w)
        w = self._step5a(w)
        w = self._step5b(w)
        return w
    }
}

/// ── Text Processor ─────────────────────────────────────────────────────

let TOKEN_RE = re.compile("[a-z]+")

class TextProcessor {
    fn new() -> TextProcessor {
        let tp = TextProcessor {}
        tp._stemmer = PorterStemmer.new()
        return tp
    }

    fn stem(self, word: string) -> string {
        return self._stemmer.stem(word)
    }

    fn tokenize(self, text: string) -> List[any] {
        return TOKEN_RE.findall(text.lower())
    }

    fn remove_stopwords(self, tokens: List[string]) -> List[any] {
        let result: List[string] = []
        for t in tokens {
            if t not in STOP_WORDS && t.len() > 1 {
                result.append(t)
            }
        }
        return result
    }

    fn extract_ngrams(self, tokens: List[string], n: int) -> List[any] {
        if tokens.len() < n { return [] }
        let result: List[string] = []
        let i = 0
        while i <= tokens.len() - n {
            result.append(tokens[i:i + n].join("_"))
            i += 1
        }
        return result
    }

    fn normalize(self, text: string) -> List[any] {
        let tokens = self.tokenize(text)
        tokens = self.remove_stopwords(tokens)
        let stemmed: List[string] = []
        for t in tokens {
            stemmed.append(self._stemmer.stem(t))
        }
        return stemmed
    }
}

/// ── TF-IDF Engine ──────────────────────────────────────────────────────

class TFIDFEngine {
    fn new() -> TFIDFEngine {
        let e = TFIDFEngine {}
        e._documents = {}
        e._idf_cache = {}
        e._processor = TextProcessor.new()
        e._dirty = true
        return e
    }

    fn add_document(self, doc_id: string, text: string) -> void {
        self._documents[doc_id] = self._processor.normalize(text)
        self._dirty = true
    }

    fn remove_document(self, doc_id: string) -> void {
        if doc_id in self._documents {
            self._documents.remove(doc_id)
        }
        self._dirty = true
    }

    fn _compute_idf(self) -> void {
        if !self._dirty { return }
        let n = self._documents.len()
        if n == 0 {
            self._idf_cache = {}
            self._dirty = false
            return
        }
        let df: Dict[string, int] = {}
        for doc_id, tokens in self._documents.items() {
            let unique_terms = Set.from(tokens)
            for term in unique_terms {
                df[term] = df.get(term, 0) + 1
            }
        }
        self._idf_cache = {}
        for t, d in df.items() {
            self._idf_cache[t] = math.log(n / d)
        }
        self._dirty = false
    }

    fn tf_idf(self, doc_id: string) -> Dict[string, float] {
        self._compute_idf()
        let tokens = self._documents.get(doc_id, None)
        if tokens == None || tokens.len() == 0 { return {} }
        let tf = counter(tokens)
        let length = tokens.len()
        let result: Dict[string, float] = {}
        for t, c in tf.items() {
            result[t] = (c / length) * self._idf_cache.get(t, 0.0)
        }
        return result
    }

    fn query_similarity(self, query: string, top_k: int) -> List[any] {
        self._compute_idf()
        let q_tokens = self._processor.normalize(query)
        if q_tokens.len() == 0 || self._documents.len() == 0 { return [] }

        let tf_q = counter(q_tokens)
        let q_len = q_tokens.len()
        let q_vec: Dict[string, float] = {}
        for t, c in tf_q.items() {
            q_vec[t] = (c / q_len) * self._idf_cache.get(t, 0.0)
        }

        let results: List[List[any]] = []
        for doc_id in self._documents.keys() {
            let score = _cosine(q_vec, self.tf_idf(doc_id))
            if score > 0.0 {
                results.append([doc_id, score])
            }
        }
        results.sort_by(fn(x) { return -x[1] })
        return results[0:top_k]
    }

    fn document_similarity(self, doc_a: string, doc_b: string) -> float {
        let va = self.tf_idf(doc_a)
        let vb = self.tf_idf(doc_b)
        if va.len() == 0 || vb.len() == 0 { return 0.0 }
        return _cosine(va, vb)
    }
}

fn _cosine(vec_a: Dict[string, float], vec_b: Dict[string, float]) -> float {
    if vec_a.len() == 0 || vec_b.len() == 0 { return 0.0 }
    let a = vec_a
    let b = vec_b
    if a.len() > b.len() {
        a = vec_b
        b = vec_a
    }
    let dot = 0.0
    for k, v in a.items() {
        if k in b {
            dot += v * b[k]
        }
    }
    if dot == 0.0 { return 0.0 }
    let mag_a = 0.0
    for v in a.values() { mag_a += v * v }
    mag_a = math.sqrt(mag_a)
    let mag_b = 0.0
    for v in b.values() { mag_b += v * v }
    mag_b = math.sqrt(mag_b)
    let denom = mag_a * mag_b
    if denom <= 0.0 { return 0.0 }
    return dot / denom
}

/// ── BM25 Engine ────────────────────────────────────────────────────────

class BM25Engine {
    fn new(k1: float, b: float) -> BM25Engine {
        let e = BM25Engine {}
        e._k1 = k1
        e._b = b
        e._documents = {}
        e._doc_lengths = {}
        e._avg_doc_length = 0.0
        e._df = {}
        e._processor = TextProcessor.new()
        return e
    }

    fn add_document(self, doc_id: string, text: string) -> void {
        let tokens = self._processor.normalize(text)
        if doc_id in self._documents {
            self._remove_doc_stats(doc_id)
        }
        self._documents[doc_id] = tokens
        self._doc_lengths[doc_id] = tokens.len()
        let unique = Set.from(tokens)
        for term in unique {
            self._df[term] = self._df.get(term, 0) + 1
        }
        let total = 0
        for v in self._doc_lengths.values() { total += v }
        if self._documents.len() > 0 {
            self._avg_doc_length = total / self._documents.len()
        } else {
            self._avg_doc_length = 0.0
        }
    }

    fn remove_document(self, doc_id: string) -> void {
        if doc_id not in self._documents { return }
        self._remove_doc_stats(doc_id)
        self._documents.remove(doc_id)
        self._doc_lengths.remove(doc_id)
        let total = 0
        for v in self._doc_lengths.values() { total += v }
        if self._documents.len() > 0 {
            self._avg_doc_length = total / self._documents.len()
        } else {
            self._avg_doc_length = 0.0
        }
    }

    fn _remove_doc_stats(self, doc_id: string) -> void {
        let unique = Set.from(self._documents[doc_id])
        for term in unique {
            self._df[term] = self._df.get(term, 0) - 1
            if self._df[term] <= 0 {
                self._df.remove(term)
            }
        }
    }

    fn score(self, query: string) -> List[any] {
        let query_terms = self._processor.normalize(query)
        if query_terms.len() == 0 || self._documents.len() == 0 { return [] }
        let results: List[List[any]] = []
        for doc_id in self._documents.keys() {
            let s = self._bm25_score(query_terms, doc_id)
            if s > 0.0 {
                results.append([doc_id, s])
            }
        }
        results.sort_by(fn(x) { return -x[1] })
        return results
    }

    fn _bm25_score(self, query_terms: List[string], doc_id: string) -> float {
        let doc = self._documents[doc_id]
        let doc_len = self._doc_lengths[doc_id]
        let tf = counter(doc)
        let n_docs = self._documents.len()
        let avgdl = self._avg_doc_length
        if avgdl <= 0.0 { avgdl = 1.0 }

        let total = 0.0
        for q in query_terms {
            let f = tf.get(q, 0)
            if f == 0 { continue }
            let df_val = self._df.get(q, 0)
            let idf = math.log(1.0 + (n_docs - df_val + 0.5) / (df_val + 0.5))
            let num = f * (self._k1 + 1.0)
            let den = f + self._k1 * (1.0 - self._b + self._b * doc_len / avgdl)
            total += idf * num / den
        }
        return total
    }
}

