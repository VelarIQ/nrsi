let HYPERNYM_DATA: Dict[string, string] = {
    "dog": "animal", "cat": "animal", "bird": "animal",
    "fish": "animal", "horse": "animal", "whale": "animal",
    "apple": "fruit", "banana": "fruit", "orange": "fruit",
    "grape": "fruit", "peach": "fruit", "mango": "fruit",
    "car": "vehicle", "bus": "vehicle", "truck": "vehicle",
    "bicycle": "vehicle", "motorcycle": "vehicle", "train": "vehicle",
    "python": "language", "java": "language", "rust": "language",
    "oak": "tree", "pine": "tree", "maple": "tree",
    "gold": "metal", "silver": "metal", "iron": "metal",
    "doctor": "profession", "lawyer": "profession", "teacher": "profession",
    "soccer": "sport", "tennis": "sport", "basketball": "sport",
    "rifle": "weapon", "sword": "weapon", "cannon": "weapon",
    "dollar": "currency", "euro": "currency", "yen": "currency",
    "earth": "planet", "mars": "planet", "venus": "planet",
    "hydrogen": "element", "oxygen": "element", "carbon": "element"
}

let RELATED_DATA: Dict[string, List[string]] = {
    "car": ["road", "drive", "engine", "wheel", "fuel", "highway"],
    "computer": ["keyboard", "monitor", "software", "internet", "code"],
    "hospital": ["doctor", "nurse", "patient", "medicine", "surgery"],
    "school": ["teacher", "student", "classroom", "education", "learn"],
    "ocean": ["wave", "fish", "coral", "tide", "shore", "depth"],
    "forest": ["tree", "wildlife", "leaf", "soil", "canopy", "trail"],
    "city": ["building", "road", "traffic", "population", "urban"],
    "war": ["soldier", "weapon", "strategy", "casualty", "territory"],
    "election": ["candidate", "voter", "campaign", "debate", "ballot"],
    "economy": ["market", "trade", "growth", "inflation", "employment"],
    "music": ["rhythm", "melody", "harmony", "instrument", "composer"],
    "space": ["star", "galaxy", "orbit", "astronaut", "rocket"]
}

class ConceptNetwork {
    fn new() -> ConceptNetwork {
        let cn = ConceptNetwork {}
        cn._synonyms = {}
        cn._hypernyms = {}
        cn._related = {}
        cn._load_core_concepts()
        return cn
    }

    fn _load_core_concepts(self) -> void {
        let stemmer = PorterStemmer.new()

        for group_str in SYNONYM_DATA {
            let words = Set.from(group_str.split(" "))
            let stems: Set[string] = Set.new()
            for w in words {
                stems.add(stemmer.stem(w))
            }
            let all_forms = words.union(stems)
            for form in all_forms {
                if form not in self._synonyms {
                    self._synonyms[form] = Set.new()
                }
                for other in all_forms {
                    if other != form {
                        self._synonyms[form].add(other)
                    }
                }
            }
        }

        for child, parent in HYPERNYM_DATA.items() {
            if child not in self._hypernyms { self._hypernyms[child] = Set.new() }
            self._hypernyms[child].add(parent)
            let c_stem = stemmer.stem(child)
            if c_stem != child {
                if c_stem not in self._hypernyms { self._hypernyms[c_stem] = Set.new() }
                self._hypernyms[c_stem].add(parent)
            }
        }

        for word, related_list in RELATED_DATA.items() {
            if word not in self._related { self._related[word] = Set.new() }
            for r in related_list {
                self._related[word].add(r)
            }
            let w_stem = stemmer.stem(word)
            if w_stem != word {
                if w_stem not in self._related { self._related[w_stem] = Set.new() }
                for r in related_list {
                    self._related[w_stem].add(r)
                }
            }
        }
    }

    fn synonyms(self, word: string) -> any {
        let result = self._synonyms.get(word, None)
        if result != None { return Set.copy(result) }
        let suffixes = ["li", "i", "er", "est", "ment", "ness"]
        for sfx in suffixes {
            if word.endswith(sfx) && word.len() > sfx.len() + 2 {
                let truncated = word[0:-sfx.len()]
                result = self._synonyms.get(truncated, None)
                if result != None { return Set.copy(result) }
            }
        }
        return Set.new()
    }

    fn expand_query(self, tokens: List[string]) -> List[any] {
        let seen: Set[string] = Set.new()
        let expanded: List[string] = []
        for token in tokens {
            if token not in seen {
                seen.add(token)
                expanded.append(token)
            }
            let syns = self._synonyms.get(token, Set.new())
            let sorted_syns = syns.sorted()
            for syn in sorted_syns {
                if syn not in seen {
                    seen.add(syn)
                    expanded.append(syn)
                }
            }
        }
        return expanded
    }

    fn similarity(self, word_a: string, word_b: string) -> float {
        if word_a == word_b { return 1.0 }
        let syns_a = self.synonyms(word_a)
        if word_b in syns_a { return 0.9 }
        let syns_b = self.synonyms(word_b)
        if syns_a.intersection(syns_b).len() > 0 { return 0.7 }
        let hyp_a = self._hypernyms.get(word_a, Set.new())
        let hyp_b = self._hypernyms.get(word_b, Set.new())
        if word_b in hyp_a || word_a in hyp_b { return 0.6 }
        if hyp_a.intersection(hyp_b).len() > 0 { return 0.4 }
        let rel_a = self._related.get(word_a, Set.new())
        if word_b in rel_a { return 0.3 }
        let rel_b = self._related.get(word_b, Set.new())
        if word_a in rel_b { return 0.3 }
        return 0.0
    }

    fn add_synonym(self, word_a: string, word_b: string) -> void {
        if word_a not in self._synonyms { self._synonyms[word_a] = Set.new() }
        self._synonyms[word_a].add(word_b)
        if word_b not in self._synonyms { self._synonyms[word_b] = Set.new() }
        self._synonyms[word_b].add(word_a)
    }

    fn add_hypernym(self, word: string, hypernym: string) -> void {
        if word not in self._hypernyms { self._hypernyms[word] = Set.new() }
        self._hypernyms[word].add(hypernym)
    }
}

/// ── Semantic Engine — unified API ──────────────────────────────────────

class SemanticEngine {
    fn new() -> SemanticEngine {
        let se = SemanticEngine {}
        se._tfidf = TFIDFEngine.new()
        se._bm25 = BM25Engine.new(1.5, 0.75)
        se._concepts = ConceptNetwork.new()
        se._processor = TextProcessor.new()
        return se
    }

    fn similarity(self, text_a: string, text_b: string) -> float {
        let tokens_a = self._processor.normalize(text_a)
        let tokens_b = self._processor.normalize(text_b)

        if tokens_a.len() == 0 && tokens_b.len() == 0 { return 1.0 }
        if tokens_a.len() == 0 || tokens_b.len() == 0 { return 0.0 }

        let set_a = Set.from(tokens_a)
        let set_b = Set.from(tokens_b)

        let union_set = set_a.union(set_b)
        let intersect = set_a.intersection(set_b)
        let jaccard = 0.0
        if union_set.len() > 0 { jaccard = intersect.len() / union_set.len() }

        let exp_a = Set.from(self._concepts.expand_query(tokens_a))
        let exp_b = Set.from(self._concepts.expand_query(tokens_b))
        let exp_union = exp_a.union(exp_b)
        let syn_jaccard = 0.0
        if exp_union.len() > 0 {
            syn_jaccard = exp_a.intersection(exp_b).len() / exp_union.len()
        }

        let len_a = tokens_a.len()
        let len_b = tokens_b.len()
        let tf_a: Dict[string, float] = {}
        let count_a = counter(tokens_a)
        for t, c in count_a.items() { tf_a[t] = c / len_a }
        let tf_b: Dict[string, float] = {}
        let count_b = counter(tokens_b)
        for t, c in count_b.items() { tf_b[t] = c / len_b }
        let tf_cos = _cosine(tf_a, tf_b)

        let soft_scores: List[float] = []
        for ta in set_a {
            let best = 0.0
            for tb in set_b {
                let s = self._concepts.similarity(ta, tb)
                if s > best { best = s }
            }
            soft_scores.append(best)
        }
        for tb in set_b {
            let best = 0.0
            for ta in set_a {
                let s = self._concepts.similarity(tb, ta)
                if s > best { best = s }
            }
            soft_scores.append(best)
        }
        let soft_sim = 0.0
        if soft_scores.len() > 0 {
            let total = 0.0
            for ss in soft_scores { total += ss }
            soft_sim = total / soft_scores.len()
        }

        let bg_a = Set.from(self._processor.extract_ngrams(tokens_a, 2))
        let bg_b = Set.from(self._processor.extract_ngrams(tokens_b, 2))
        let bg_union = bg_a.union(bg_b)
        let bigram_sim = 0.0
        if bg_union.len() > 0 {
            bigram_sim = bg_a.intersection(bg_b).len() / bg_union.len()
        }

        let score = 0.20 * jaccard + 0.20 * syn_jaccard + 0.15 * tf_cos + 0.35 * soft_sim + 0.10 * bigram_sim
        if score < 0.0 { score = 0.0 }
        if score > 1.0 { score = 1.0 }
        return score
    }

    fn best_match(self, query: string, candidates: List[string], top_k: int) -> List[any] {
        let scored: List[List[any]] = []
        let idx = 0
        for candidate in candidates {
            let s = self.similarity(query, candidate)
            scored.append([candidate, s, idx])
            idx += 1
        }
        scored.sort_by(fn(x) { return -x[1] })
        return scored[0:top_k]
    }

    fn is_relevant(self, text: string, query: string, threshold: float) -> bool {
        return self.similarity(text, query) >= threshold
    }

    fn extract_key_concepts(self, text: string) -> List[any] {
        let tokens = self._processor.normalize(text)
        if tokens.len() == 0 { return [] }
        let tf = counter(tokens)
        let total = tokens.len()
        let unique = tf.len()

        let scores: Dict[string, float] = {}
        for term, count in tf.items() {
            let freq = count / total
            let rarity = math.log(1.0 + unique / count)
            let specificity = term.len() / 6.0
            if specificity > 1.5 { specificity = 1.5 }
            scores[term] = freq * rarity * specificity
        }

        let max_s = 1.0
        for v in scores.values() {
            if v > max_s { max_s = v }
        }
        let result: List[List[any]] = []
        for t, s in scores.items() {
            result.append([t, s / max_s])
        }
        result.sort_by(fn(x) { return -x[1] })
        return result
    }

    fn cluster_by_topic(self, texts: List[string], n_clusters: int) -> Dict[int, List[int]] {
        let n = texts.len()
        if n == 0 { return {} }
        if n_clusters > n { n_clusters = n }
        if n_clusters <= 1 {
            let indices: List[int] = []
            let i = 0
            while i < n { indices.append(i); i += 1 }
            return {0: indices}
        }

        let sim: Dict[string, float] = {}
        let i = 0
        while i < n {
            let j = i + 1
            while j < n {
                let s = self.similarity(texts[i], texts[j])
                sim[string(i) + ":" + string(j)] = s
                sim[string(j) + ":" + string(i)] = s
                j += 1
            }
            i += 1
        }

        fn _sim(a: int, b: int) -> float {
            if a == b { return 1.0 }
            return sim.get(string(a) + ":" + string(b), 0.0)
        }

        let medoids: List[int] = [0]
        let medoid_set: Set[int] = Set.of(0)
        let mc = 1
        while mc < n_clusters {
            let best_idx = -1
            let lowest_nearest = 999999.0
            let ci = 0
            while ci < n {
                if ci in medoid_set { ci += 1; continue }
                let nearest = -1.0
                for m in medoids {
                    let sv = _sim(ci, m)
                    if sv > nearest { nearest = sv }
                }
                if nearest < lowest_nearest {
                    lowest_nearest = nearest
                    best_idx = ci
                }
                ci += 1
            }
            if best_idx < 0 { break }
            medoids.append(best_idx)
            medoid_set.add(best_idx)
            mc += 1
        }

        let clusters: Dict[int, List[int]] = {}
        let ci = 0
        while ci < n {
            let best_c = 0
            let best_s = -1.0
            let mi = 0
            while mi < medoids.len() {
                let sv = _sim(ci, medoids[mi])
                if sv > best_s {
                    best_s = sv
                    best_c = mi
                }
                mi += 1
            }
            if best_c not in clusters { clusters[best_c] = [] }
            clusters[best_c].append(ci)
            ci += 1
        }
        return clusters
    }

    fn expand_query(self, query: string) -> string {
        let tokens = self._processor.normalize(query)
        let expanded = self._concepts.expand_query(tokens)
        return expanded.join(" ")
    }

    fn stats(self) -> Dict[string, any] {
        let syn_pairs = 0
        for v in self._concepts._synonyms.values() { syn_pairs += v.len() }
        let hyp_count = 0
        for v in self._concepts._hypernyms.values() { hyp_count += v.len() }
        let rel_count = 0
        for v in self._concepts._related.values() { rel_count += v.len() }
        return {
            "tfidf_documents": self._tfidf._documents.len(),
            "bm25_documents": self._bm25._documents.len(),
            "concept_synonym_keys": self._concepts._synonyms.len(),
            "concept_synonym_pairs": syn_pairs,
            "concept_hypernyms": hyp_count,
            "concept_related": rel_count,
            "stop_words": STOP_WORDS.len()
        }
    }

    fn tfidf(self) -> TFIDFEngine { return self._tfidf }
    fn bm25(self) -> BM25Engine { return self._bm25 }
    fn concepts(self) -> ConceptNetwork { return self._concepts }
    fn processor(self) -> TextProcessor { return self._processor }
}

export TextProcessor, TFIDFEngine, BM25Engine, ConceptNetwork, SemanticEngine
