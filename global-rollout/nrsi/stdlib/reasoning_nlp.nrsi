        "strengthens": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "accelerate": { "rel": RelationType.CAUSES, "mod": 0.8 },
        "accelerates": { "rel": RelationType.CAUSES, "mod": 0.8 },
        "convert": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "converts": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "transform": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "transforms": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "affect": { "rel": RelationType.CAUSES, "mod": 0.75 },
        "affects": { "rel": RelationType.CAUSES, "mod": 0.75 },
        "influence": { "rel": RelationType.CAUSES, "mod": 0.7 },
        "influences": { "rel": RelationType.CAUSES, "mod": 0.7 },
        "support": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "supports": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "protect": { "rel": RelationType.PREVENTS, "mod": 0.8 },
        "protects": { "rel": RelationType.PREVENTS, "mod": 0.8 },
        "regulate": { "rel": RelationType.CAUSES, "mod": 0.75 },
        "regulates": { "rel": RelationType.CAUSES, "mod": 0.75 },
        "control": { "rel": RelationType.CAUSES, "mod": 0.7 },
        "controls": { "rel": RelationType.CAUSES, "mod": 0.7 },
        "drive": { "rel": RelationType.CAUSES, "mod": 0.8 },
        "drives": { "rel": RelationType.CAUSES, "mod": 0.8 },
        "power": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "powers": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "emit": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "emits": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "absorb": { "rel": RelationType.REQUIRES, "mod": 0.7 },
        "absorbs": { "rel": RelationType.REQUIRES, "mod": 0.7 },
        "connect": { "rel": RelationType.CORRELATES, "mod": 0.7 },
        "connects": { "rel": RelationType.CORRELATES, "mod": 0.7 },
        "help": { "rel": RelationType.ENABLES, "mod": 0.7 },
        "helps": { "rel": RelationType.ENABLES, "mod": 0.7 },
        "harm": { "rel": RelationType.CAUSES, "mod": 0.75 },
        "harms": { "rel": RelationType.CAUSES, "mod": 0.75 },
        "form": { "rel": RelationType.PRODUCES, "mod": 0.7 },
        "forms": { "rel": RelationType.PRODUCES, "mod": 0.7 },
        "provide": { "rel": RelationType.ENABLES, "mod": 0.7 },
        "provides": { "rel": RelationType.ENABLES, "mod": 0.7 },
        "use": { "rel": RelationType.REQUIRES, "mod": 0.7 },
        "uses": { "rel": RelationType.REQUIRES, "mod": 0.7 },
        "comprise": { "rel": RelationType.PART_OF, "mod": 0.8 },
        "comprises": { "rel": RelationType.PART_OF, "mod": 0.8 }
    }
    return map.get(vl, nil)
}

/// ── SVO Extraction ──

fn _extract_svo(sent: string) -> List[any] {
    let results = []

    /// Passive: "Y is/are verb-ed by X"
    let m_passive = re.match(
        "^(.+?)\\s+(?:is|are|was|were)\\s+(\\w+ed)\\s+by\\s+(.+?)$", sent)
    if m_passive != nil {
        let obj_raw = m_passive.group(1)
        let verb = m_passive.group(2)
        let subj_raw = m_passive.group(3)
        let base_verb = re.sub("ed$", "", verb.lower())
        for v in _verb_relation_keys() {
            let lookup = _verb_relation_lookup(v)
            if lookup == nil { continue }
            if v.starts_with(base_verb) || base_verb.starts_with(v.slice(0, 4)) {
                let subj = _clean_concept(subj_raw)
                let obj = _clean_concept(obj_raw)
                if subj.len() > 0 && obj.len() > 0 && subj != obj {
                    results.append(SVO {
                        subject: subj, verb: verb, obj: obj,
                        relation: lookup["rel"], confidence_modifier: lookup["mod"]
                    })
                }
                break
            }
        }
    }

    /// "due to" pattern: "Y is due to X"
    let m_due = re.match(
        "^(.+?)\\s+(?:is|are|was|were)\\s+(?:due|attributed|owing)\\s+to\\s+(.+?)$", sent)
    if m_due != nil {
        let effect = _clean_concept(m_due.group(1))
        let cause = _clean_concept(m_due.group(2))
        if cause.len() > 0 && effect.len() > 0 && cause != effect {
            results.append(SVO {
                subject: cause, verb: "causes", obj: effect,
                relation: RelationType.CAUSES, confidence_modifier: 0.85
            })
        }
    }

    /// Conditional: "When X, Y" / "If X, then Y"
    let m_cond = re.match(
        "^(?:when|if|whenever|once)\\s+(.+?)\\s*,\\s*(?:then\\s+)?(.+?)$", sent)
    if m_cond != nil {
        let condition = _clean_concept(m_cond.group(1))
        let consequence = _clean_concept(m_cond.group(2))
        if condition.len() > 0 && consequence.len() > 0 && condition != consequence {
            results.append(SVO {
                subject: condition, verb: "enables", obj: consequence,
                relation: RelationType.ENABLES, confidence_modifier: 0.75
            })
        }
    }

    /// Relative: "X, which verb Y"
    let m_rel = re.match(
        "^(.+?)\\s*,\\s*which\\s+(\\w+(?:s|es|ed)?)\\s+(.+?)$", sent)
    if m_rel != nil {
        let subj = _clean_concept(m_rel.group(1))
        let verb = m_rel.group(2)
        let obj = _clean_concept(m_rel.group(3))
        let lookup = _verb_relation_lookup(verb.lower())
        if lookup != nil && subj.len() > 0 && obj.len() > 0 && subj != obj {
            results.append(SVO {
                subject: subj, verb: verb, obj: obj,
                relation: lookup["rel"],
                confidence_modifier: to_float(lookup["mod"]) * 0.9
            })
        }
    }

    /// Copular IS_A: "X is/are a/the Y"
    let m_isa = re.match(
        "^(.+?)\\s+(?:is|are|was|were)\\s+(?:a|an|the)\\s+(.+?)$", sent)
    if m_isa != nil {
        let subj = _clean_concept(m_isa.group(1))
        let obj = _clean_concept(m_isa.group(2))
        if subj.len() > 2 && obj.len() > 2 && subj != obj {
            let already = false
            for s in results {
                if s.subject == subj && s.obj == obj && s.relation == RelationType.IS_A {
                    already = true
                    break
                }
            }
            if !already {
                results.append(SVO {
                    subject: subj, verb: "is", obj: obj,
                    relation: RelationType.IS_A, confidence_modifier: 0.8
                })
            }
        }
    }

    /// Copular alias: "X is known as Y"
    let m_alias = re.match(
        "^(.+?)\\s+(?:is|are)\\s+(?:known as|called|named|referred to as|termed)\\s+(.+?)$", sent)
    if m_alias != nil {
        let subj = _clean_concept(m_alias.group(1))
        let obj = _clean_concept(m_alias.group(2))
        if subj.len() > 0 && obj.len() > 0 && subj != obj {
            results.append(SVO {
                subject: subj, verb: "is", obj: obj,
                relation: RelationType.IS_A, confidence_modifier: 0.85
            })
        }
    }

    /// Direct verb lookup scan
    let words = sent.split(" ")
    for i in range(0, words.len()) {
        let lookup = _verb_relation_lookup(words[i].lower())
        if lookup == nil { continue }
        if i < 1 || i >= words.len() - 1 { continue }
        let subj_parts = []
        for j in range(0, i) {
            subj_parts.append(words[j])
        }
        let obj_parts = []
        for j in range(i + 1, words.len()) {
            obj_parts.append(words[j])
        }
        let subj = _clean_concept(subj_parts.join(" "))
        let obj = _clean_concept(obj_parts.join(" "))
        if subj.len() > 2 && obj.len() > 2 && subj != obj {
            let already = false
            for s in results {
                if s.subject == subj && s.obj == obj && s.relation == lookup["rel"] {
                    already = true
                    break
                }
            }
            if !already {
                results.append(SVO {
                    subject: subj, verb: words[i], obj: obj,
                    relation: lookup["rel"], confidence_modifier: lookup["mod"]
                })
                break
            }
        }
    }

    return results
}

fn _verb_relation_keys() -> List[any] {
    return [
        "cause", "causes", "caused", "lead", "leads", "result", "results",
        "produce", "produces", "generate", "generates", "create", "creates",
        "prevent", "prevents", "block", "blocks", "inhibit", "inhibits",
        "suppress", "suppresses", "reduce", "reduces", "require", "requires",
        "need", "needs", "depend", "depends", "enable", "enables",
        "allow", "allows", "facilitate", "facilitates", "contain", "contains",
        "include", "includes", "involve", "involves", "contradict", "contradicts",
        "oppose", "opposes", "precede", "precedes", "correlate", "correlates",
        "trigger", "triggers", "increase", "increases", "decrease", "decreases",
        "promote", "promotes", "improve", "improves", "weaken", "weakens",
        "strengthen", "strengthens", "accelerate", "accelerates",
        "convert", "converts", "transform", "transforms",
        "affect", "affects", "influence", "influences", "support", "supports",
        "protect", "protects", "regulate", "regulates", "control", "controls",
        "drive", "drives", "power", "powers", "emit", "emits",
        "absorb", "absorbs", "connect", "connects", "help", "helps",
        "harm", "harms", "form", "forms", "provide", "provides",
        "use", "uses", "comprise", "comprises"
    ]
}

/// ── Enhanced Fact Extractor ──

class EnhancedFactExtractor {
    fn init(self) {
        self._fallback = FactExtractor()
    }

    fn extract_from_text(self, text: string, confidence: float,
                         fact_id: string, domain: string) -> List[any] {
        let sentences = _split_sentences(text)
        let resolved = _resolve_coreferences(sentences)
        let triples = []
        let seen = set()

        for sent in resolved {
            let svos = _extract_svo(sent)
            for svo in svos {
                let key = svo.subject + "|" + svo.relation.value + "|" + svo.obj
                if seen.contains(key) { continue }
                seen.add(key)
                triples.append(ExtractedTriple {
                    subject: svo.subject,
                    relation: svo.relation,
                    obj: svo.obj,
                    confidence: confidence * svo.confidence_modifier,
                    evidence: sent,
                    fact_id: fact_id,
                    domain: domain
                })
            }

            if svos.len() == 0 {
                let fallback_triples = self._fallback.extract_from_text(
                    sent, confidence, fact_id, domain)
                for t in fallback_triples {
                    let key = t.subject + "|" + t.relation.value + "|" + t.obj
                    if !seen.contains(key) {
                        seen.add(key)
                        triples.append(t)
                    }
                }
            }
        }
        return triples
    }

    fn extract_from_facts(self, facts: List[Map[string, any]],
                          domain: string) -> List[any] {
        let all_triples = []
        for fact in facts {
            let text = to_string(fact.get("text", ""))
            let conf = to_float(fact.get("confidence", 0.5))
            let fid = to_string(fact.get("id", ""))
            let d = domain
            if d == "" {
                d = to_string(fact.get("domain", ""))
            }
            let triples = self.extract_from_text(text, conf, fid, d)
            for t in triples {
                all_triples.append(t)
            }
        }
        return all_triples
    }

    fn populate_graph(self, graph: CausalGraph,
                      facts: List[Map[string, any]],
                      domain: string) -> int {
        let triples = self.extract_from_facts(facts, domain)
        for t in triples {
            graph.add_edge(
                t.subject, t.obj, t.relation,
                t.confidence, t.domain, t.evidence, t.fact_id)
        }
        return triples.len()
    }
}

export SVO, EnhancedFactExtractor
export _split_sentences, _resolve_coreferences, _extract_noun_phrases, _extract_svo
