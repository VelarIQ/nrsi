/// NRS Reasoning — Enhanced NLP Pipeline.
///
/// Noun-phrase chunking, dependency-pattern templates, coreference-lite
/// resolution, and clause splitting for high triple extraction yield.
///
/// Multi-pass pipeline:
///   1. Sentence splitting (semicolons, conjunctions, relative clauses)
///   2. Coreference resolution (pronouns → antecedents)
///   3. Noun-phrase chunking (subject/object spans)
///   4. Dependency-pattern matching (SVO, passive, copular, relative)
///   5. Quality filtering (confidence, concept length, dedup)
///
/// All transformer-free. No external ML dependencies.
/// Ported from nrsip/reasoning_nlp.py.

module reasoning_nlp

import re from "std/re"
import CausalGraph, ExtractedTriple, FactExtractor, RelationType,
       _clean_concept from "reasoning_graph"

/// ── POS-like tag heuristics (no model, regex-based) ──

let _DETERMINERS = {
    "a", "an", "the", "this", "that", "these", "those", "my", "your",
    "his", "her", "its", "our", "their", "some", "any", "no", "every",
    "each", "all", "both", "few", "several", "many", "much"
}

let _PREPOSITIONS = {
    "in", "on", "at", "to", "for", "with", "by", "from", "of", "as",
    "into", "through", "during", "before", "after", "above", "below",
    "between", "among", "within", "without", "about", "against",
    "across", "along", "around", "behind", "beside", "beyond",
    "near", "over", "under", "upon", "towards", "via"
}

let _PRONOUNS = {
    "it", "they", "them", "he", "she", "him", "her", "we", "us",
    "its", "their", "his", "her", "our", "this", "that", "these",
    "those", "which", "who", "whom", "whose"
}

let _AUXILIARY = {
    "is", "are", "was", "were", "be", "been", "being",
    "has", "have", "had", "having",
    "do", "does", "did",
    "will", "would", "shall", "should", "can", "could", "may", "might",
    "must", "need", "dare", "ought"
}

let _ADJ_SUFFIXES = [
    "al", "ous", "ive", "ful", "less", "able", "ible", "ic", "ed"
]

fn _is_likely_noun(word: string) -> bool {
    let wl = word.lower()
    if _DETERMINERS.contains(wl) { return false }
    if _PREPOSITIONS.contains(wl) { return false }
    if _PRONOUNS.contains(wl) { return false }
    if _AUXILIARY.contains(wl) { return false }
    if wl.ends_with("ly") && wl.len() > 4 {
        return false
    }
    return true
}

/// ── Sentence Splitter ──

fn _split_sentences(text: string) -> List[any] {
    let cleaned = re.sub("\\s+", " ", text.strip())
    let sents = re.split("(?<=[.!?;])\\s+(?=[A-Z])", cleaned)
    let result = []
    for s in sents {
        let trimmed = s.strip()
        if trimmed.ends_with(".") {
            trimmed = trimmed.slice(0, trimmed.len() - 1)
        }
        if trimmed.len() < 8 {
            continue
        }
        let conjunctions = re.split(
            ",\\s*(?:and|but|while|whereas|although|however)\\s+", trimmed)
        if conjunctions.len() > 1 {
            let all_long = true
            for c in conjunctions {
                if c.len() <= 15 {
                    all_long = false
                    break
                }
            }
            if all_long {
                for c in conjunctions {
                    let ct = c.strip()
                    if ct.len() > 8 {
                        result.append(ct)
                    }
                }
            } else {
                result.append(trimmed)
            }
        } else {
            result.append(trimmed)
        }
    }
    return result
}

/// ── Coreference Resolution (lightweight) ──

fn _extract_leading_np(sent: string) -> string {
    let words = sent.split(" ")
    let np_words = []
    for w in words {
        if _DETERMINERS.contains(w.lower()) {
            continue
        }
        if _is_likely_noun(w) || w.char_at(0).is_upper() {
            np_words.append(w)
        } else {
            break
        }
        if np_words.len() >= 4 {
            break
        }
    }
    return np_words.join(" ")
}

fn _replace_pronouns(sent: string, antecedent: string) -> string {
    let words = sent.split(" ")
    let result = []
    for i in range(0, words.len()) {
        let wl = words[i].lower()
        if wl == "it" || wl == "this" || wl == "they" || wl == "these" {
            if i == 0 {
                result.append(antecedent)
                continue
            }
            if i > 0 && _AUXILIARY.contains(words[i - 1].lower()) {
                result.append(antecedent)
                continue
            }
        }
        result.append(words[i])
    }
    return result.join(" ")
}

fn _resolve_coreferences(sentences: List[string]) -> List[any] {
    let resolved = []
    let last_subject = ""
    for sent in sentences {
        let np = _extract_leading_np(sent)
        if np.len() > 3 {
            last_subject = np
        }
        let s = sent
        if last_subject.len() > 0 {
            s = _replace_pronouns(sent, last_subject)
        }
        resolved.append(s)
    }
    return resolved
}

/// ── Noun-Phrase Chunker ──

fn _extract_noun_phrases(text: string) -> List[any] {
    let pattern = "(?:(?:the|a|an|this|that|these|those|its|their|his|her|our|my|your)\\s+)?" +
        "(?:(?:[a-z]+-)?(?:[a-z]+(?:al|ous|ive|ic|ed|ing|ary|ory)\\s+))*" +
        "(?:[A-Za-z][a-z]+(?:\\s+[A-Za-z][a-z]+){0,4})" +
        "(?:\\s+(?:of|for|in|on|with|from|by)\\s+" +
        "(?:(?:the|a|an)\\s+)?[A-Za-z][a-z]+(?:\\s+[A-Za-z][a-z]+){0,2})?"
    let matches = re.findall(pattern, text)
    let phrases = []
    for m in matches {
        let cleaned = _clean_concept(m)
        if cleaned.len() > 2 {
            phrases.append(cleaned)
        }
    }
    return phrases
}

/// ── SVO (Subject-Verb-Object) ──

type SVO {
    subject: string,
    verb: string,
    obj: string,
    relation: RelationType,
    confidence_modifier: float
}

/// Verb → (RelationType, confidence_modifier) mapping
fn _verb_relation_lookup(verb: string) -> Optional[any] {
    let vl = verb.lower()
    let map = {
        "cause": { "rel": RelationType.CAUSES, "mod": 1.0 },
        "causes": { "rel": RelationType.CAUSES, "mod": 1.0 },
        "caused": { "rel": RelationType.CAUSES, "mod": 0.95 },
        "lead": { "rel": RelationType.CAUSES, "mod": 0.9 },
        "leads": { "rel": RelationType.CAUSES, "mod": 0.9 },
        "result": { "rel": RelationType.CAUSES, "mod": 0.85 },
        "results": { "rel": RelationType.CAUSES, "mod": 0.85 },
        "produce": { "rel": RelationType.PRODUCES, "mod": 1.0 },
        "produces": { "rel": RelationType.PRODUCES, "mod": 1.0 },
        "generate": { "rel": RelationType.PRODUCES, "mod": 0.9 },
        "generates": { "rel": RelationType.PRODUCES, "mod": 0.9 },
        "create": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "creates": { "rel": RelationType.PRODUCES, "mod": 0.85 },
        "prevent": { "rel": RelationType.PREVENTS, "mod": 1.0 },
        "prevents": { "rel": RelationType.PREVENTS, "mod": 1.0 },
        "block": { "rel": RelationType.PREVENTS, "mod": 0.9 },
        "blocks": { "rel": RelationType.PREVENTS, "mod": 0.9 },
        "inhibit": { "rel": RelationType.INHIBITS, "mod": 1.0 },
        "inhibits": { "rel": RelationType.INHIBITS, "mod": 1.0 },
        "suppress": { "rel": RelationType.INHIBITS, "mod": 0.9 },
        "suppresses": { "rel": RelationType.INHIBITS, "mod": 0.9 },
        "reduce": { "rel": RelationType.INHIBITS, "mod": 0.8 },
        "reduces": { "rel": RelationType.INHIBITS, "mod": 0.8 },
        "require": { "rel": RelationType.REQUIRES, "mod": 1.0 },
        "requires": { "rel": RelationType.REQUIRES, "mod": 1.0 },
        "need": { "rel": RelationType.REQUIRES, "mod": 0.9 },
        "needs": { "rel": RelationType.REQUIRES, "mod": 0.9 },
        "depend": { "rel": RelationType.REQUIRES, "mod": 0.85 },
        "depends": { "rel": RelationType.REQUIRES, "mod": 0.85 },
        "enable": { "rel": RelationType.ENABLES, "mod": 1.0 },
        "enables": { "rel": RelationType.ENABLES, "mod": 1.0 },
        "allow": { "rel": RelationType.ENABLES, "mod": 0.9 },
        "allows": { "rel": RelationType.ENABLES, "mod": 0.9 },
        "facilitate": { "rel": RelationType.ENABLES, "mod": 0.85 },
        "facilitates": { "rel": RelationType.ENABLES, "mod": 0.85 },
        "contain": { "rel": RelationType.PART_OF, "mod": 0.8 },
        "contains": { "rel": RelationType.PART_OF, "mod": 0.8 },
        "include": { "rel": RelationType.PART_OF, "mod": 0.75 },
        "includes": { "rel": RelationType.PART_OF, "mod": 0.75 },
        "involve": { "rel": RelationType.PART_OF, "mod": 0.7 },
        "involves": { "rel": RelationType.PART_OF, "mod": 0.7 },
        "contradict": { "rel": RelationType.CONTRADICTS, "mod": 1.0 },
        "contradicts": { "rel": RelationType.CONTRADICTS, "mod": 1.0 },
        "oppose": { "rel": RelationType.CONTRADICTS, "mod": 0.85 },
        "opposes": { "rel": RelationType.CONTRADICTS, "mod": 0.85 },
        "precede": { "rel": RelationType.PRECEDES, "mod": 0.9 },
        "precedes": { "rel": RelationType.PRECEDES, "mod": 0.9 },
        "correlate": { "rel": RelationType.CORRELATES, "mod": 0.8 },
        "correlates": { "rel": RelationType.CORRELATES, "mod": 0.8 },
        "trigger": { "rel": RelationType.CAUSES, "mod": 0.9 },
        "triggers": { "rel": RelationType.CAUSES, "mod": 0.9 },
        "increase": { "rel": RelationType.CAUSES, "mod": 0.7 },
        "increases": { "rel": RelationType.CAUSES, "mod": 0.7 },
        "decrease": { "rel": RelationType.INHIBITS, "mod": 0.7 },
        "decreases": { "rel": RelationType.INHIBITS, "mod": 0.7 },
        "promote": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "promotes": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "improve": { "rel": RelationType.ENABLES, "mod": 0.8 },
        "improves": { "rel": RelationType.ENABLES, "mod": 0.8 },
