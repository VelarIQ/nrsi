//  SECTION 2 — TYPE DEFINITIONS
// ═══════════════════════════════════════════════════════════════════

type SignalingRecord {
    row_index: int,
    timestamp: float,
    event_type: string,
    result_code: string,
    cell_id: string,
    lac: string,
    rnc_bsc: string,
    msc: string,
    smsc: string,
    imsi_hash: string,
    duration_ms: float,
    retry_count: int,
    signal_strength: float,
    timing_advance: float,
    frequency_band: string,
    technology: string,
    raw_fields: Dict[string, string]
}

type TowerProfile {
    cell_id: string,
    lac: string,
    rnc_bsc: string,
    total_events: int,
    success_count: int,
    failure_count: int,
    failure_rate: float,
    error_distribution: Dict[string, int],
    unique_subscribers: int,
    avg_duration_ms: float,
    avg_retry_count: float,
    first_event: float,
    last_event: float,
    anomaly_scores: Dict[string, float],
    evidence_items: List[EvidenceItem],
    band_distribution: Dict[string, int],
    band_failure_rates: Dict[string, float],
    technology_distribution: Dict[string, int],
    primary_band: string,
    primary_technology: string
}

type EvidenceItem {
    dimension: string,
    metric: string,
    anomaly_score: float,
    confidence: float,
    row_indices: List[int],
    reasoning: string,
    tower_id: string,
    comparison_value: string
}

type ChangePoint {
    timestamp: float,
    metric: string,
    before_value: float,
    after_value: float,
    significance: float,
    row_index: int
}

type FaultHypothesis {
    tower_id: string,
    fault_domain: string,
    fault_severity: string,
    confidence: float,
    evidence: List[EvidenceItem],
    root_cause: string,
    explanation: string,
    recommendations: List[string],
    change_point: Optional[ChangePoint],
    provenance_hash: string
}

type AnalysisReport {
    report_id: string,
    timestamp: float,
    elapsed_ms: float,
    total_records: int,
    total_towers: int,
    primary_fault: FaultHypothesis,
    alternative_hypotheses: List[FaultHypothesis],
    network_health: Dict[string, float],
    data_quality: Dict[string, float],
    reasoning_chain: List[string],
    trust_level: string,
    provenance_hash: string
}


