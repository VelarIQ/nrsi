/// NRS Knowledge Pipeline — Enforced Knowledge Sourcing Strategy.
///
/// This module answers the question: "Where does the answer come from?"
///
/// Unlike LLMs that hallucinate from compressed training data, NRS
/// follows an explicit, auditable knowledge resolution chain:
///
///   Level 0: SEEDED KNOWLEDGE (belief bases, axioms, domain creases)
///            → Deterministic, versioned, zero hallucination risk
///            → Confidence: 0.95-1.0
///
///   Level 1: LOCAL REASONING (causal graph, logic engine, inference)
///            → Derived from seeded knowledge via verified rules
///            → Confidence: 0.80-0.95 (depends on chain length)
///
///   Level 2: CACHED KNOWLEDGE (previously retrieved + validated facts)
///            → Web-sourced but already verified and stored
///            → Confidence: 0.70-0.90 (depends on source + age)
///
///   Level 3: GATED WEB RETRIEVAL (live retrieval with credibility gates)
///            → Only triggered when L0-L2 fail
///            → Subject to source credibility, cross-reference, freshness
///            → Confidence: 0.40-0.75 (never above 0.75 for web-only)
///
///   Level 4: ABSTAIN (explicit "I don't know")
///            → When no level produces sufficient confidence
///            → Returns structured uncertainty with gap description
///            → Confidence: 0.0 (honest zero)
///
/// The pipeline NEVER silently falls through. Every answer carries:
///   - Which level sourced it
///   - The evidence chain
///   - A calibrated confidence score
///   - Whether the system would abstain at a given threshold
///
/// This is the fundamental difference from OpenAI: we don't guess.
/// We either know, can derive, can verify from web, or we say so.

module nrs_knowledge_pipeline

import time from "std/time"
import math from "std/math"
import json from "std/json"
import hashlib from "std/hashlib"
import logging from "std/logging"

let logger = logging.getLogger("nrs.knowledge-pipeline")


// ═══════════════════════════════════════════════════════════════════
//  TYPES
// ═══════════════════════════════════════════════════════════════════

enum KnowledgeLevel {
    SEEDED = "seeded",
    REASONED = "reasoned",
    CACHED = "cached",
    WEB_RETRIEVED = "web_retrieved",
    ABSTAINED = "abstained"
}

enum AbstainReason {
    NO_KNOWLEDGE = "no_knowledge",
    LOW_CONFIDENCE = "low_confidence",
    CONFLICTING_SOURCES = "conflicting_sources",
    STALE_DATA = "stale_data",
    OUTSIDE_DOMAIN = "outside_domain",
    SAFETY_GATE = "safety_gate"
}

type EvidenceLink {
    source: string,
    source_type: string,
    content: string,
    confidence: float,
    timestamp: float,
    verifiable: bool
}

type KnowledgeResolution {
    query: string,
    answer: string,
    level: string,
    confidence: float,
    calibrated_confidence: float,
    evidence: List[EvidenceLink],
    reasoning_chain: List[string],
    abstain_reason: string,
    gap_description: string,
    levels_attempted: List[string],
    elapsed_ms: float,
    provenance_hash: string,
    would_abstain_at: float
}

type ConfidenceCalibration {
    raw: float,
    source_penalty: float,
    chain_decay: float,
    age_decay: float,
    cross_ref_bonus: float,
    calibrated: float
}


// ═══════════════════════════════════════════════════════════════════
//  CONFIDENCE CALIBRATION
// ═══════════════════════════════════════════════════════════════════

/// Calibrate raw confidence based on source, chain length, age, and
/// cross-referencing. This is the core anti-hallucination mechanism:
/// confidence is REDUCED, never inflated.
class ConfidenceCalibrator {

    fn init(self) {
        // Source-type reliability priors (empirically grounded)
        self._source_priors = {
            "axiom": 0.99,
            "belief_base": 0.95,
            "domain_crease": 0.93,
            "logic_derivation": 0.90,
            "causal_inference": 0.85,
            "cached_verified": 0.80,
            "cached_unverified": 0.60,
            "web_authoritative": 0.70,
            "web_general": 0.50,
            "web_social": 0.30,
            "web_unknown": 0.25,
            "user_input": 0.40,
            "generated": 0.20
        }

        // Chain length decay: each reasoning step reduces confidence
        self._chain_decay_rate = 0.05

        // Age decay: knowledge loses confidence over time
        self._age_half_life_days = {
            "axiom": 36500.0,
            "science": 1825.0,
            "technology": 365.0,
            "news": 7.0,
            "market": 1.0,
            "default": 730.0
        }

        // Cross-reference bonus: independent sources increase confidence
        self._cross_ref_bonus_per_source = 0.05
        self._cross_ref_max_bonus = 0.15
    }

    fn calibrate(self, raw_confidence: float, source_type: string,
                 chain_length: int, age_seconds: float,
                 domain: string, cross_ref_count: int) -> ConfidenceCalibration {

        // Source prior: cap confidence by source reliability
        let source_prior = self._source_priors.get(source_type, 0.40)
        let source_penalty = max(0.0, raw_confidence - source_prior)
        let after_source = min(raw_confidence, source_prior)

        // Chain decay: longer derivation chains = less certain
        let decay = float(chain_length) * self._chain_decay_rate
        let chain_penalty = min(decay, 0.30)
        let after_chain = max(after_source - chain_penalty, 0.0)

        // Age decay: exponential decay based on domain half-life
        let half_life = self._age_half_life_days.get(domain,
                        self._age_half_life_days["default"])
        let age_days = age_seconds / 86400.0
        let age_factor = 1.0
        if age_days > 0.0 and half_life > 0.0 {
            age_factor = math.pow(0.5, age_days / half_life)
        }
        let age_penalty = after_chain * (1.0 - age_factor)
        let after_age = after_chain * age_factor

        // Cross-reference bonus: independent confirmation
        let xref_bonus = min(
            float(cross_ref_count) * self._cross_ref_bonus_per_source,
            self._cross_ref_max_bonus
        )
        let calibrated = min(after_age + xref_bonus, 0.99)

        return ConfidenceCalibration {
            raw: raw_confidence,
            source_penalty: source_penalty,
            chain_decay: chain_penalty,
            age_decay: age_penalty,
            cross_ref_bonus: xref_bonus,
            calibrated: calibrated
        }
    }
}


// ═══════════════════════════════════════════════════════════════════
//  LEVEL 0: SEEDED KNOWLEDGE
// ═══════════════════════════════════════════════════════════════════

class SeededKnowledgeResolver {

    fn init(self) {
        self._belief_bases: List[Any] = []
        self._axiom_index: Dict[string, List[Dict[string, Any]]] = {}
        self._domain_creases: Dict[string, Any] = {}
    }

    fn register_belief_base(self, name: string, base: Any) {
        append(self._belief_bases, {"name": name, "base": base})
    }

    fn register_crease(self, domain: string, crease: Any) {
        self._domain_creases[domain] = crease
    }

    fn index_axiom(self, keyword: string, axiom: Dict[string, Any]) {
        if keyword not in self._axiom_index {
            self._axiom_index[keyword] = []
        }
        append(self._axiom_index[keyword], axiom)
    }

    fn resolve(self, query: string, domain: string) -> Optional[KnowledgeResolution] {
        let t0 = time.time()
        let query_lower = query.lower()
        let tokens = query_lower.split()

        // Search axiom index
        let matches: List[Dict[string, Any]] = []
        for token in tokens {
            if token in self._axiom_index {
                for axiom in self._axiom_index[token] {
                    if axiom not in matches {
                        append(matches, axiom)
                    }
                }
            }
        }

        // Search belief bases
        for bb in self._belief_bases {
            let base = bb["base"]
            if hasattr(base, "query") {
                let results = base.query(query)
                if results != None and len(results) > 0 {
                    for r in results {
                        append(matches, {
                            "content": str(r),
                            "confidence": 0.95,
                            "source": "belief_base:" + bb["name"],
                            "source_type": "belief_base"
                        })
                    }
                }
            }
        }

        // Search domain creases
        if domain in self._domain_creases {
            let crease = self._domain_creases[domain]
            if hasattr(crease, "lookup") {
                let result = crease.lookup(query)
                if result != None {
                    append(matches, {
                        "content": str(result),
                        "confidence": 0.93,
                        "source": "domain_crease:" + domain,
                        "source_type": "domain_crease"
                    })
                }
            }
        }

        if len(matches) == 0 { return None }

        // Pick best match
        let best = matches[0]
        for m in matches {
            if m.get("confidence", 0.0) > best.get("confidence", 0.0) {
                best = m
            }
        }

        let evidence = [EvidenceLink {
            source: best.get("source", "seeded"),
            source_type: best.get("source_type", "axiom"),
            content: best.get("content", ""),
            confidence: best.get("confidence", 0.95),
            timestamp: time.time(),
            verifiable: true
        }]

        let elapsed = (time.time() - t0) * 1000.0
        let answer = best.get("content", "")
        let prov = hashlib.sha256(answer.encode("utf-8")).hexdigest()[0:16]

        return KnowledgeResolution {
            query: query,
            answer: answer,
            level: "seeded",
            confidence: best.get("confidence", 0.95),
            calibrated_confidence: best.get("confidence", 0.95),
            evidence: evidence,
            reasoning_chain: ["L0: seeded knowledge match"],
            abstain_reason: "",
            gap_description: "",
            levels_attempted: ["seeded"],
            elapsed_ms: elapsed,
            provenance_hash: prov,
            would_abstain_at: best.get("confidence", 0.95)
        }
    }
}


// ═══════════════════════════════════════════════════════════════════
//  LEVEL 1: LOCAL REASONING
// ═══════════════════════════════════════════════════════════════════

class LocalReasoningResolver {

    fn init(self) {
        self._causal_graph = None
        self._logic_engine = None
        self._calibrator = ConfidenceCalibrator()
    }

    fn set_causal_graph(self, graph: Any) { self._causal_graph = graph }
    fn set_logic_engine(self, engine: Any) { self._logic_engine = engine }

    fn resolve(self, query: string, domain: string) -> Optional[KnowledgeResolution] {
        let t0 = time.time()
        let evidence: List[EvidenceLink] = []
        let chain: List[string] = []
        let best_answer = ""
        let best_conf = 0.0

        // Try causal graph inference
        if self._causal_graph != None {
            try {
                let graph = self._causal_graph
                if hasattr(graph, "query_paths") {
                    let paths = graph.query_paths(query)
                    if paths != None and len(paths) > 0 {
                        let path = paths[0]
                        let chain_len = len(path.get("nodes", []))
                        let raw_conf = path.get("confidence", 0.7)

                        let cal = self._calibrator.calibrate(
                            raw_conf, "causal_inference", chain_len,
                            0.0, domain, 0
                        )

                        if cal.calibrated > best_conf {
                            best_answer = path.get("conclusion", str(path))
                            best_conf = cal.calibrated
                            append(evidence, EvidenceLink {
                                source: "causal_graph",
                                source_type: "causal_inference",
                                content: best_answer,
                                confidence: cal.calibrated,
                                timestamp: time.time(),
                                verifiable: true
                            })
                            append(chain, "L1: causal graph path (length=" + str(chain_len) + ")")
                        }
                    }
                }
            } catch {}
        }

        // Try logic engine
        if self._logic_engine != None {
            try {
                let engine = self._logic_engine
                if hasattr(engine, "prove") {
                    let proof = engine.prove(query)
                    if proof != None and proof.get("proved", false) {
                        let steps = proof.get("steps", [])
                        let raw_conf = proof.get("confidence", 0.85)

                        let cal = self._calibrator.calibrate(
                            raw_conf, "logic_derivation", len(steps),
                            0.0, domain, 0
                        )

                        if cal.calibrated > best_conf {
                            best_answer = proof.get("conclusion", str(proof))
                            best_conf = cal.calibrated
                            append(evidence, EvidenceLink {
                                source: "logic_engine",
                                source_type: "logic_derivation",
                                content: best_answer,
                                confidence: cal.calibrated,
                                timestamp: time.time(),
                                verifiable: true
                            })
                            append(chain, "L1: logical proof (" + str(len(steps)) + " steps)")
                        }
                    }
                }
            } catch {}
        }

        if best_conf == 0.0 { return None }

        let elapsed = (time.time() - t0) * 1000.0
        let prov = hashlib.sha256(best_answer.encode("utf-8")).hexdigest()[0:16]

        return KnowledgeResolution {
            query: query,
            answer: best_answer,
            level: "reasoned",
            confidence: best_conf,
            calibrated_confidence: best_conf,
            evidence: evidence,
            reasoning_chain: chain,
            abstain_reason: "",
            gap_description: "",
            levels_attempted: ["seeded", "reasoned"],
            elapsed_ms: elapsed,
            provenance_hash: prov,
            would_abstain_at: best_conf
        }
    }
}


// ═══════════════════════════════════════════════════════════════════
//  LEVEL 2: CACHED KNOWLEDGE
// ═══════════════════════════════════════════════════════════════════

class CachedKnowledgeResolver {

    fn init(self) {
        self._cache: Dict[string, Dict[string, Any]] = {}
        self._calibrator = ConfidenceCalibrator()
        self._max_age_seconds = 604800.0
    }

    fn store(self, query_hash: string, answer: string, source: string,
             confidence: float, domain: string) {
        self._cache[query_hash] = {
            "answer": answer,
            "source": source,
            "confidence": confidence,
            "domain": domain,
            "stored_at": time.time(),
            "access_count": 0,
            "verified": false
        }
    }

    fn mark_verified(self, query_hash: string) {
        if query_hash in self._cache {
            self._cache[query_hash]["verified"] = true
        }
    }

    fn resolve(self, query: string, domain: string) -> Optional[KnowledgeResolution] {
        let t0 = time.time()
        let qhash = hashlib.sha256(query.lower().encode("utf-8")).hexdigest()[0:32]

        if qhash not in self._cache { return None }

        let entry = self._cache[qhash]
        let age = time.time() - entry["stored_at"]

        // Reject stale entries
        if age > self._max_age_seconds { return None }

        let source_type = "cached_verified" if entry["verified"] else "cached_unverified"
        let cal = self._calibrator.calibrate(
            entry["confidence"], source_type, 0, age, domain, 0
        )

        // Reject if calibrated confidence is too low
        if cal.calibrated < 0.40 { return None }

        entry["access_count"] = entry["access_count"] + 1

        let evidence = [EvidenceLink {
            source: "cache:" + entry["source"],
            source_type: source_type,
            content: entry["answer"],
            confidence: cal.calibrated,
            timestamp: entry["stored_at"],
            verifiable: entry["verified"]
        }]

        let elapsed = (time.time() - t0) * 1000.0
        let prov = hashlib.sha256(entry["answer"].encode("utf-8")).hexdigest()[0:16]

        return KnowledgeResolution {
            query: query,
            answer: entry["answer"],
            level: "cached",
            confidence: cal.calibrated,
            calibrated_confidence: cal.calibrated,
            evidence: evidence,
            reasoning_chain: ["L2: cached knowledge (age=" + str(int(age)) + "s, verified=" + str(entry["verified"]) + ")"],
            abstain_reason: "",
            gap_description: "",
            levels_attempted: ["seeded", "reasoned", "cached"],
            elapsed_ms: elapsed,
            provenance_hash: prov,
            would_abstain_at: cal.calibrated
        }
    }
}


// ═══════════════════════════════════════════════════════════════════
//  LEVEL 3: GATED WEB RETRIEVAL
// ═══════════════════════════════════════════════════════════════════

class GatedWebResolver {

    fn init(self) {
        self._retrieval_fn = None
        self._calibrator = ConfidenceCalibrator()
        self._web_confidence_cap = 0.75
        self._min_source_credibility = 0.30
        self._require_cross_reference = true
        self._min_cross_refs = 2

        // Source credibility tiers
        self._source_credibility = {
            "gov": 0.85,
            "edu": 0.80,
            "org": 0.65,
            "established_media": 0.60,
            "reference": 0.75,
            "commercial": 0.40,
            "social": 0.25,
            "unknown": 0.20
        }
    }

    fn set_retrieval_fn(self, fn: Any) {
        self._retrieval_fn = fn
    }

    fn resolve(self, query: string, domain: string) -> Optional[KnowledgeResolution] {
        let t0 = time.time()

        if self._retrieval_fn == None { return None }

        try {
            let results = self._retrieval_fn(query)
            if results == None or len(results) == 0 { return None }

            // Score and filter results by credibility
            let scored: List[Dict[string, Any]] = []
            for r in results {
                let url = r.get("url", r.get("source", ""))
                let credibility = self._assess_credibility(url)
                if credibility < self._min_source_credibility { continue }

                append(scored, {
                    "content": r.get("content", r.get("text", str(r))),
                    "source": url,
                    "credibility": credibility,
                    "raw_confidence": r.get("confidence", r.get("relevance", 0.5))
                })
            }

            if len(scored) == 0 { return None }

            // Cross-reference check: do multiple sources agree?
            let cross_ref_count = len(scored)
            if self._require_cross_reference and cross_ref_count < self._min_cross_refs {
                // Single source is not enough for web knowledge
                logger.info("Web retrieval: only %d source(s), need %d for cross-ref",
                           cross_ref_count, self._min_cross_refs)
            }

            // Use best-credibility source
            let best = scored[0]
            for s in scored {
                if s["credibility"] > best["credibility"] { best = s }
            }

            let raw_conf = min(best["raw_confidence"] * best["credibility"],
                              self._web_confidence_cap)

            let cal = self._calibrator.calibrate(
                raw_conf, "web_authoritative" if best["credibility"] > 0.6 else "web_general",
                0, 0.0, domain, cross_ref_count
            )

            // Hard cap: web knowledge never exceeds 0.75
            let final_conf = min(cal.calibrated, self._web_confidence_cap)

            let evidence: List[EvidenceLink] = []
            for s in scored {
                append(evidence, EvidenceLink {
                    source: s["source"],
                    source_type: "web_retrieval",
                    content: s["content"][0:500],
                    confidence: s["credibility"],
                    timestamp: time.time(),
                    verifiable: true
                })
            }

            let elapsed = (time.time() - t0) * 1000.0
            let answer = best["content"]
            let prov = hashlib.sha256(answer.encode("utf-8")).hexdigest()[0:16]

            return KnowledgeResolution {
                query: query,
                answer: answer,
                level: "web_retrieved",
                confidence: final_conf,
                calibrated_confidence: final_conf,
                evidence: evidence,
                reasoning_chain: [
                    "L3: web retrieval (" + str(len(scored)) + " sources, best credibility=" + format_float(best["credibility"], 2) + ")"
                ],
                abstain_reason: "",
                gap_description: "",
                levels_attempted: ["seeded", "reasoned", "cached", "web_retrieved"],
                elapsed_ms: elapsed,
                provenance_hash: prov,
                would_abstain_at: final_conf
            }
        } catch as e {
            logger.warning("Web retrieval failed: %s", str(e))
            return None
        }
    }

    fn _assess_credibility(self, url: string) -> float {
        let lower = url.lower()

        if ".gov" in lower or ".mil" in lower { return self._source_credibility["gov"] }
        if ".edu" in lower or ".ac." in lower { return self._source_credibility["edu"] }

        let reference_domains = ["wikipedia.org", "britannica.com", "pubmed.ncbi",
                                  "arxiv.org", "nature.com", "science.org",
                                  "ieee.org", "rfc-editor.org", "ietf.org",
                                  "who.int", "cdc.gov", "nih.gov"]
        for rd in reference_domains {
            if rd in lower { return self._source_credibility["reference"] }
        }

        let established = ["reuters.com", "apnews.com", "bbc.com", "nytimes.com",
                           "wsj.com", "ft.com", "economist.com"]
        for em in established {
            if em in lower { return self._source_credibility["established_media"] }
        }

        if ".org" in lower { return self._source_credibility["org"] }

        let social = ["twitter.com", "x.com", "reddit.com", "facebook.com",
                      "tiktok.com", "instagram.com", "youtube.com"]
        for s in social {
            if s in lower { return self._source_credibility["social"] }
        }

        if ".com" in lower or ".net" in lower { return self._source_credibility["commercial"] }

        return self._source_credibility["unknown"]
    }
}


// ═══════════════════════════════════════════════════════════════════
//  LEVEL 4: ABSTENTION
// ═══════════════════════════════════════════════════════════════════

fn _build_abstention(query: string, reason: string, gap: string,
                     levels: List[string], t0: float) -> KnowledgeResolution {
    let elapsed = (time.time() - t0) * 1000.0
    return KnowledgeResolution {
        query: query,
        answer: "",
        level: "abstained",
        confidence: 0.0,
        calibrated_confidence: 0.0,
        evidence: [],
        reasoning_chain: ["L4: abstained — " + reason],
        abstain_reason: reason,
        gap_description: gap,
        levels_attempted: levels,
        elapsed_ms: elapsed,
        provenance_hash: "",
        would_abstain_at: 0.0
    }
}


// ═══════════════════════════════════════════════════════════════════
//  MAIN PIPELINE
// ═══════════════════════════════════════════════════════════════════

class KnowledgePipeline {

    fn init(self) {
        self._seeded = SeededKnowledgeResolver()
        self._reasoned = LocalReasoningResolver()
        self._cached = CachedKnowledgeResolver()
        self._web = GatedWebResolver()
        self._calibrator = ConfidenceCalibrator()

        // Minimum confidence to return an answer (below = abstain)
        self._abstain_threshold = 0.40

        // Whether to allow web retrieval at all
        self._web_enabled = true

        // Stats
        self._stats = {
            "total_queries": 0,
            "level_seeded": 0,
            "level_reasoned": 0,
            "level_cached": 0,
            "level_web": 0,
            "level_abstained": 0,
            "avg_confidence": 0.0
        }
    }

    fn set_abstain_threshold(self, threshold: float) {
        self._abstain_threshold = threshold
    }

    fn enable_web(self, enabled: bool) {
        self._web_enabled = enabled
    }

    fn set_web_retrieval(self, fn: Any) {
        self._web.set_retrieval_fn(fn)
    }

    fn set_causal_graph(self, graph: Any) {
        self._reasoned.set_causal_graph(graph)
    }

    fn set_logic_engine(self, engine: Any) {
        self._reasoned.set_logic_engine(engine)
    }

    fn register_belief_base(self, name: string, base: Any) {
        self._seeded.register_belief_base(name, base)
    }

    fn register_crease(self, domain: string, crease: Any) {
        self._seeded.register_crease(domain, crease)
    }

    fn index_axiom(self, keyword: string, axiom: Dict[string, Any]) {
        self._seeded.index_axiom(keyword, axiom)
    }

    /// The main entry point. Resolves a query through the knowledge
    /// hierarchy: seeded → reasoned → cached → web → abstain.
    fn resolve(self, query: string, domain: string) -> KnowledgeResolution {
        let t0 = time.time()
        self._stats["total_queries"] = self._stats["total_queries"] + 1

        // Level 0: Seeded knowledge
        let result = self._seeded.resolve(query, domain)
        if result != None and result.calibrated_confidence >= self._abstain_threshold {
            self._stats["level_seeded"] = self._stats["level_seeded"] + 1
            self._update_avg(result.calibrated_confidence)
            return result
        }

        // Level 1: Local reasoning
        let reasoned = self._reasoned.resolve(query, domain)
        if reasoned != None and reasoned.calibrated_confidence >= self._abstain_threshold {
            self._stats["level_reasoned"] = self._stats["level_reasoned"] + 1
            self._update_avg(reasoned.calibrated_confidence)
            return reasoned
        }

        // Level 2: Cached knowledge
        let cached = self._cached.resolve(query, domain)
        if cached != None and cached.calibrated_confidence >= self._abstain_threshold {
            self._stats["level_cached"] = self._stats["level_cached"] + 1
            self._update_avg(cached.calibrated_confidence)
            return cached
        }

        // Level 3: Gated web retrieval (only if enabled)
        if self._web_enabled {
            let web_result = self._web.resolve(query, domain)
            if web_result != None and web_result.calibrated_confidence >= self._abstain_threshold {
                // Cache the web result for future use
                let qhash = hashlib.sha256(query.lower().encode("utf-8")).hexdigest()[0:32]
                self._cached.store(qhash, web_result.answer,
                                   web_result.evidence[0].source if len(web_result.evidence) > 0 else "web",
                                   web_result.calibrated_confidence, domain)
                self._stats["level_web"] = self._stats["level_web"] + 1
                self._update_avg(web_result.calibrated_confidence)
                return web_result
            }
        }

        // Level 4: Abstain
        self._stats["level_abstained"] = self._stats["level_abstained"] + 1

        // Build informative gap description
        let gap = "No knowledge source produced confidence >= " + format_float(self._abstain_threshold, 2)
        let reason = "no_knowledge"

        // Check if we had low-confidence results
        let best_attempt = None
        let best_conf = 0.0
        if result != None and result.calibrated_confidence > best_conf {
            best_attempt = result
            best_conf = result.calibrated_confidence
        }
        if reasoned != None and reasoned.calibrated_confidence > best_conf {
            best_attempt = reasoned
            best_conf = reasoned.calibrated_confidence
        }
        if cached != None and cached.calibrated_confidence > best_conf {
            best_attempt = cached
            best_conf = cached.calibrated_confidence
        }

        if best_conf > 0.0 {
            reason = "low_confidence"
            gap = "Best attempt: " + best_attempt.level + " at " + format_float(best_conf, 2) + " confidence (threshold: " + format_float(self._abstain_threshold, 2) + ")"
        }

        let levels = ["seeded", "reasoned", "cached"]
        if self._web_enabled { append(levels, "web_retrieved") }
        append(levels, "abstained")

        return _build_abstention(query, reason, gap, levels, t0)
    }

    fn stats(self) -> Dict[string, Any] {
        return self._stats
    }

    fn _update_avg(self, conf: float) {
        let total = self._stats["total_queries"]
        let old_avg = self._stats["avg_confidence"]
        self._stats["avg_confidence"] = old_avg + (conf - old_avg) / float(max(total, 1))
    }
}


// ═══════════════════════════════════════════════════════════════════
//  SINGLETON
// ═══════════════════════════════════════════════════════════════════

let _global_pipeline: Optional[KnowledgePipeline] = None

fn get_pipeline() -> KnowledgePipeline {
    if _global_pipeline == None {
        _global_pipeline = KnowledgePipeline()
    }
    return _global_pipeline
}


// ═══════════════════════════════════════════════════════════════════
//  NORMS (these now actually enforce via the fixed transpiler)
// ═══════════════════════════════════════════════════════════════════

norm never_return_ungrounded_answer {
    type: prohibition,
    scope: global,
    action: "resolve",
    priority: 99,
    condition: confidence == 0.0 and level != "abstained"
}

norm web_never_exceeds_cap {
    type: prohibition,
    scope: global,
    action: "resolve",
    priority: 98,
    condition: level == "web_retrieved" and calibrated_confidence > 0.75
}

norm abstain_below_threshold {
    type: obligation,
    scope: global,
    action: "resolve",
    priority: 97,
    condition: calibrated_confidence < 0.40 and level != "abstained"
}

norm require_evidence_chain {
    type: obligation,
    scope: global,
    action: "resolve",
    priority: 95,
    condition: level != "abstained"
}


// ═══════════════════════════════════════════════════════════════════
//  EXPORTS
// ═══════════════════════════════════════════════════════════════════

export KnowledgeLevel, AbstainReason, EvidenceLink, KnowledgeResolution
export ConfidenceCalibration, ConfidenceCalibrator
export SeededKnowledgeResolver, LocalReasoningResolver
export CachedKnowledgeResolver, GatedWebResolver
export KnowledgePipeline, get_pipeline
