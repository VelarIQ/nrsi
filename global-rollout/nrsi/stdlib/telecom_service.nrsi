//   EXPORTS
// ═══════════════════════════════════════════════════════════════════

export AnalyzeRequest, AnalyzeResponse, HealthResponse, StreamEvent, ValidationResult
export EventType, AnalysisPhase
export TelecomAnalysisService
export handle_analyze, handle_analyze_stream, handle_health
export handle_report_text, handle_report_json
export SERVICE_VERSION, SERVICE_NAME
